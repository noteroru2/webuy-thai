---
import { getSiteUrl } from '../lib/site';

interface Props {
	to: string;
}
const { to } = Astro.props;
const canonical = getSiteUrl(to);
---
<!doctype html>
<html lang="th">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<meta http-equiv="refresh" content={`0;url=${to}`} />
		<link rel="canonical" href={canonical} />
		<title>ย้ายที่อยู่แล้ว</title>
	</head>
	<body
		style="margin:0;font-family:system-ui,sans-serif;padding:1.5rem;background:#fffaf5;color:#333;"
	>
		<p>
			<a href={to} style="color:#e67300;font-weight:700;">ไปยังหน้าที่อัปเดตแล้ว</a>
		</p>
	</body>
</html>
