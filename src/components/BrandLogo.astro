---
---

<a class="brand" href="/">
	<span class="brand-mark" aria-hidden="true">
		<svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg" class="brand-mark-svg">
			<defs>
				<linearGradient id="brand-w-grad" x1="36" y1="12" x2="36" y2="58" gradientUnits="userSpaceOnUse">
					<stop stop-color="#ffe566" />
					<stop offset="0.25" stop-color="#ffc23d" />
					<stop offset="0.58" stop-color="#ff9500" />
					<stop offset="1" stop-color="#d95400" />
				</linearGradient>
				<linearGradient id="brand-accent" x1="10" y1="36" x2="62" y2="36" gradientUnits="userSpaceOnUse">
					<stop stop-color="#ffb366" stop-opacity="0.25" />
					<stop offset="0.5" stop-color="#ff9933" stop-opacity="0.40" />
					<stop offset="1" stop-color="#ffb366" stop-opacity="0.25" />
				</linearGradient>
			</defs>
			<rect
				x="3" y="3" width="66" height="66" rx="18"
				fill="#ffffff"
				stroke="rgba(255,165,100,0.38)"
				stroke-width="1.1"
			/>
			<path
				d="M 9 42 Q 36 22 63 42"
				stroke="url(#brand-accent)"
				stroke-width="1.3"
				stroke-linecap="round"
				fill="none"
			/>
			<path
				d="M 9 34 Q 36 54 63 34"
				stroke="url(#brand-accent)"
				stroke-width="1.15"
				stroke-linecap="round"
				fill="none"
				opacity="0.88"
			/>
			<path
				fill="url(#brand-w-grad)"
				d="M 10 14 L 23 57 L 36 23 L 49 57 L 62 14 L 53 14 L 46 43 L 36 31 L 26 43 L 19 14 Z"
			/>
		</svg>
	</span>
	<span class="brand-copy">
		<span class="brand-line1">
			<span class="brand-we">WE BUY</span>
			<span class="brand-sep" aria-hidden="true">|</span>
			<span class="brand-th">เรารับซื้อ</span>
		</span>
		<span class="brand-line2">รับซื้อ โน๊ตบุ๊ค คอมพิวเตอร์ ไอโฟน</span>
	</span>
</a>

<style>
	.brand {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		text-decoration: none;
		line-height: 1.2;
		max-width: min(100%, 28rem);
		min-width: 0;
	}
	.brand:hover {
		text-decoration: none;
		opacity: 0.97;
	}
	.brand-mark {
		flex-shrink: 0;
		width: clamp(56px, 16vw, 80px);
		height: clamp(56px, 16vw, 80px);
		display: block;
	}
	.brand-mark-svg {
		width: 100%;
		height: 100%;
		display: block;
		filter: drop-shadow(0 3px 14px rgba(255, 130, 0, 0.2));
	}
	.brand-copy {
		display: flex;
		flex-direction: column;
		gap: 0.22rem;
		min-width: 0;
	}
	.brand-line1 {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.15rem 0.35rem;
		font-size: clamp(1.05rem, 3.2vw, 1.32rem);
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.brand-we {
		background: linear-gradient(180deg, #ffb020 0%, #ff8c00 45%, #cc4f00 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}
	.brand-sep {
		color: rgba(255, 140, 0, 0.42);
		font-weight: 400;
		font-size: 0.9em;
	}
	.brand-th {
		color: #1f1d1a;
		font-weight: 750;
	}
	.brand-line2 {
		font-size: clamp(0.74rem, 2.1vw, 0.85rem);
		font-weight: 500;
		color: #4a4540;
		letter-spacing: 0.01em;
		line-height: 1.35;
	}
	@media (max-width: 1023px) {
		.brand {
			max-width: calc(100% - 6.25rem);
		}
		.brand-mark {
			width: clamp(58px, 21vw, 80px);
			height: clamp(58px, 21vw, 80px);
		}
	}
</style>
