---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBox from '../components/ContactBox.astro';
import '../styles/longform.css';
import { getSiteOrigin } from '../lib/site';

const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'WE BUY | เรารับซื้อ';
const serviceAreasRaw =
	import.meta.env.PUBLIC_SERVICE_AREAS ??
	'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี';
const serviceAreas = serviceAreasRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);

const faqItems = [
	{
		q: 'รับซื้อคอมพิวเตอร์ตั้งโต๊ะประเภทไหนบ้าง?',
		a: 'รับซื้อครบทุกประเภท ทั้งคอมประกอบเอง คอมแบรนด์เนม (Dell, HP, Lenovo, Acer) คอมเกมมิ่ง เวิร์กสเตชัน คอมสำนักงาน Mini PC All-in-One และเครื่องเซิร์ฟเวอร์บางรุ่น ประเมินจากสเปกจริงและสภาพการใช้งาน',
	},
	{
		q: 'คอมเก่ามากหรือสเปกต่ำยังขายได้ไหม?',
		a: 'ขายได้ หากยังมีชิ้นส่วนที่มีมูลค่าในตลาดมือสอง เช่น เคสคุณภาพดี พาวเวอร์ซัพพลายยี่ห้อดัง หรือ SSD ที่ยังสมบูรณ์ ทีมงานจะช่วยประเมินตามสภาพจริงและอธิบายเหตุผลราคาให้ชัดเจน',
	},
	{
		q: 'ต้องถอดชิ้นส่วนส่งแยกไหม?',
		a: 'ไม่ต้องถอดเลย ส่งมาทั้งเครื่องได้เลย ทีมงานมีอุปกรณ์ตรวจสอบครบและจะตรวจสเปกให้ทั้งหมด การถอดเองอาจทำให้ชิ้นส่วนเสียหายหรือสูญหายโดยไม่จำเป็น',
	},
	{
		q: 'ขายคอมต้องเตรียมอะไรบ้าง?',
		a: 'เตรียมข้อมูลสเปกเครื่อง เช่น รุ่น CPU, RAM, SSD/HDD, การ์ดจอ พร้อมถ่ายรูปเครื่องรอบด้านและภาพหน้าจอ BIOS หรือ System Information สำรองข้อมูลส่วนตัวให้เรียบร้อย แล้วทัก Line @webuy เพื่อประเมินราคาทันที',
	},
	{
		q: 'ราคาประเมินใช้เกณฑ์อะไร?',
		a: 'ดูจากหลายปัจจัยประกอบกัน ได้แก่ รุ่นและเจนของ CPU ขนาดและความเร็ว RAM ชนิดและความจุ Storage รุ่นการ์ดจอ คุณภาพพาวเวอร์ซัพพลาย สภาพเคสและเมนบอร์ด รวมถึงอายุการใช้งานและความต้องการของตลาดในขณะนั้น',
	},
	{
		q: 'รับซื้ออุปกรณ์ต่อพ่วงด้วยไหม เช่น จอ คีย์บอร์ด เมาส์?',
		a: 'รับซื้อครับ โดยเฉพาะจอมอนิเตอร์ที่ยังสภาพดี คีย์บอร์ดเมคานิคอล และเมาส์เกมมิ่ง หากขายพร้อมชุดคอมจะสะดวกในการประเมินและปิดดีลได้เร็วขึ้น',
	},
	{
		q: 'ให้บริการพื้นที่ไหนบ้าง?',
		a: 'ให้บริการหลักในกรุงเทพมหานคร ปริมณฑล และจังหวัดใหญ่ในภาคอีสาน เช่น อุบลราชธานี ขอนแก่น นครราชสีมา อุดรธานี สำหรับพื้นที่อื่นสามารถส่งรูปและสเปกมาประเมินออนไลน์ได้ก่อน แล้วค่อยนัดหมายส่งมอบ',
	},
	{
		q: 'ติดต่อช่องทางไหนเร็วที่สุด?',
		a: 'แนะนำทัก Line @webuy เพราะส่งรูป สเปก และวิดีโอเครื่องได้ทันที ทีมงานตอบกลับตลอด 24 ชั่วโมง หรือโทร 064-257-9353 หากต้องการคุยสดทันที',
	},
	{
		q: 'ขายคอมเกมมิ่งได้ราคาดีไหม?',
		a: 'คอมเกมมิ่งที่มีการ์ดจอแรง RAM เยอะ และ SSD ความจุสูง มักได้ราคาดีกว่าคอมสำนักงานทั่วไป เพราะมีความต้องการในตลาดมือสองสูง โดยเฉพาะเครื่องที่ดูแลรักษาดีและมีประวัติการใช้งานชัดเจน',
	},
	{
		q: 'ขายหลายเครื่องพร้อมกันได้ไหม?',
		a: 'ได้เลย ไม่ว่าจะเป็นบุคคลทั่วไปหรือบริษัทที่ต้องการเคลียร์คอมชุดเก่า ส่งรายการสเปคทั้งหมดมาทาง Line @webuy ได้เลย ทีมงานจะประเมินเป็นชุดและเสนอราคารวมให้ ช่วยประหยัดเวลาได้มาก',
	},
];

const articleJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: 'รับซื้อคอม | รับซื้อคอมพิวเตอร์มือสอง PC ทุกรุ่น ได้ราคาดี',
		description:
			'บริการรับซื้อคอมพิวเตอร์ตั้งโต๊ะมือสอง ครอบคลุมคอมประกอบ คอมแบรนด์เนม คอมเกมมิ่ง เวิร์กสเตชัน พร้อมคู่มือเตรียมเครื่องก่อนขายและเกณฑ์ประเมินราคาอย่างละเอียด',
		inLanguage: 'th-TH',
		author: { '@type': 'Organization', name: orgName },
		publisher: { '@type': 'Organization', name: orgName },
		mainEntityOfPage: `${site}/คอม/`,
		datePublished: '2026-03-24',
		dateModified: '2026-03-24',
		keywords:
			'รับซื้อคอม, ขายคอมมือสอง, รับซื้อคอมพิวเตอร์, รับซื้อคอมตั้งโต๊ะ, รับซื้อคอมเกมมิ่ง, รับซื้อ PC, ประเมินราคาคอม, ขายคอมเก่า, รับซื้อคอมสำนักงาน, รับซื้อเวิร์กสเตชัน',
		image: [new URL('/og-default.png', site).toString()],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
			{ '@type': 'ListItem', position: 2, name: 'รับซื้อคอม', item: `${site}/คอม/` },
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.q,
			acceptedAnswer: { '@type': 'Answer', text: item.a },
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'บริการรับซื้อคอมพิวเตอร์',
		description:
			'บริการรับซื้อคอมพิวเตอร์มือสองทุกประเภท ทั้ง PC ประกอบ คอมแบรนด์เนม Gaming PC Workstation ประเมินราคาโปร่งใส จ่ายเงินทันที',
		provider: { '@type': 'Organization', name: orgName },
		areaServed: serviceAreas.map((area) => ({ '@type': 'AdministrativeArea', name: area })),
		serviceType: 'รับซื้อคอมพิวเตอร์มือสอง',
		url: `${site}/คอม/`,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'วิธีขายคอมพิวเตอร์มือสองกับ WE BUY',
		description: 'ขั้นตอนง่าย ๆ ในการขายคอมมือสองให้ได้ราคาดี',
		step: [
			{
				'@type': 'HowToStep',
				name: 'ส่งข้อมูลเครื่อง',
				text: 'แอดไลน์ @webuy แล้วส่งรูปเครื่อง สเปก CPU, RAM, GPU และสภาพ',
			},
			{
				'@type': 'HowToStep',
				name: 'รับราคาประเมิน',
				text: 'ทีมงานตรวจสอบสเปกและแจ้งราคาประเมินเบื้องต้น',
			},
			{
				'@type': 'HowToStep',
				name: 'ยืนยันและนัดรับ',
				text: 'ตกลงราคา นัดหมายจุดรับ-ส่ง หรือจัดส่ง',
			},
			{
				'@type': 'HowToStep',
				name: 'รับเงินทันที',
				text: 'ตรวจสอบเครื่องจริงและรับเงินทันที',
			},
		],
	},
];
---

<BaseLayout
	title="รับซื้อคอม | รับซื้อคอมพิวเตอร์มือสอง PC ทุกรุ่น ได้ราคาดี | WE BUY"
	description="WE BUY รับซื้อคอมพิวเตอร์มือสองทุกประเภท คอมประกอบ คอมแบรนด์เนม Gaming PC Workstation ประเมินราคาโปร่งใส จ่ายเงินทันที ติดต่อ Line @webuy 24 ชม."
	pathname="/คอม/"
	type="article"
	jsonLd={articleJsonLd}
>
	<article class="container longform">
		<header>
			<p class="kicker">Desktop PC Buyback Service</p>
			<h1>รับซื้อคอม — บริการรับซื้อคอมพิวเตอร์ตั้งโต๊ะมือสอง ทุกรุ่น ทุกแบรนด์ ได้ราคาดี ประเมินโปร่งใส</h1>
			<p class="intro">
				ถ้าคุณกำลังมองหาที่ <strong>รับซื้อคอม</strong> ที่ให้ราคาเป็นธรรมและไม่ต้องกังวลเรื่องถูกกดราคา
				คุณมาถูกที่แล้ว ไม่ว่าจะเป็นคอมประกอบเอง คอมแบรนด์อย่าง Dell HP Lenovo คอมเกมมิ่งสเปกแรง
				เวิร์กสเตชันสำหรับงานกราฟิกหรือวิศวกรรม คอมสำนักงานที่ใช้หมดรอบแล้ว หรือแม้แต่เครื่องเซิร์ฟเวอร์
				เรารับหมด บทความนี้จะพาคุณทำความเข้าใจทุกขั้นตอนตั้งแต่เกณฑ์การประเมินราคาแต่ละชิ้นส่วน
				ไปจนถึงการเตรียมเครื่องก่อนขายและช่องทางการติดต่อที่สะดวกที่สุด
				เพื่อให้คุณตัดสินใจได้อย่างมั่นใจจากข้อมูลจริง
			</p>
		</header>

		<!-- ═══════════ ทำไมต้องขายคอมกับเรา ═══════════ -->
		<section>
			<h2>ทำไมต้องขายคอมพิวเตอร์ตั้งโต๊ะกับเรา</h2>
			<p>
				คอมพิวเตอร์ตั้งโต๊ะเป็นอุปกรณ์ที่มีชิ้นส่วนหลากหลาย ตั้งแต่ซีพียู แรม การ์ดจอ SSD พาวเวอร์ซัพพลาย
				ไปจนถึงเมนบอร์ดและเคส แต่ละชิ้นมีมูลค่าที่แตกต่างกันและเปลี่ยนแปลงตามตลาด
				การขายคอมกับร้านรับซื้อทั่วไปที่ไม่เข้าใจรายละเอียดของฮาร์ดแวร์อาจทำให้คุณได้ราคาต่ำกว่าที่ควร
				เพราะผู้ซื้อเหล่านั้นมักประเมินแบบเหมารวมโดยไม่ได้ดูคุณค่าของแต่ละชิ้นส่วนอย่างละเอียด
			</p>
			<p>
				ทีมงานของเราเข้าใจสเปกคอมพิวเตอร์เชิงลึก เราประเมินแต่ละชิ้นส่วนแยกกัน ดูทั้งรุ่น เจเนอเรชัน ยี่ห้อ
				และสภาพการใช้งานจริง จากนั้นจึงรวมเป็นราคาทั้งเครื่องที่สมเหตุสมผล พร้อมอธิบายเหตุผลให้คุณเข้าใจ
				ไม่มีการกดราคาโดยไม่มีที่มาที่ไป นอกจากนี้เรายังเปิดให้บริการตลอด 24 ชั่วโมง
				คุณสามารถทักมาสอบถามได้ทุกเวลาผ่าน
				<a class="inline-contact" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">Line @webuy</a>
				หรือโทร <a class="phone-link" href="tel:0642579353">064-257-9353</a>
				เพื่อรับการประเมินเบื้องต้นโดยไม่มีค่าใช้จ่าย
			</p>

			<h3>ความโปร่งใสในการประเมิน</h3>
			<p>
				เราเชื่อว่าการซื้อขายที่ดีเริ่มจากความไว้วางใจ ทุกครั้งที่ประเมินราคาคอมพิวเตอร์
				เราจะแจ้งราคาแต่ละชิ้นส่วนให้ชัดเจน พร้อมเหตุผลว่าทำไมชิ้นนี้ถึงได้ราคาเท่านี้
				หากมีชิ้นส่วนที่มีตำหนิหรือเสื่อมสภาพ เราจะอธิบายว่ากระทบราคาเท่าไรและเพราะอะไร
				คุณจะไม่เจอสถานการณ์ที่ถูกบอกราคาต่ำแล้วไม่รู้ว่าเพราะอะไร
			</p>

			<h3>สะดวก รวดเร็ว ไม่ต้องรอนาน</h3>
			<p>
				ส่งรูปและข้อมูลสเปกมาทาง Line แล้วรอรับราคาประเมินเบื้องต้นได้ภายในไม่กี่ชั่วโมง
				หลายเคสเราตอบกลับได้ภายใน 30 นาที สำหรับเครื่องที่ข้อมูลครบ
				เมื่อตกลงราคากันแล้ว เราพร้อมนัดรับเครื่องหรือให้คุณส่งมาได้ทันที
				จบดีลเร็ว ได้เงินเร็ว ไม่ต้องรอขายเองหลายสัปดาห์
			</p>
		</section>

		<!-- ═══════════ เกณฑ์ประเมินราคา ═══════════ -->
		<section>
			<h2>เราประเมินราคาคอมพิวเตอร์จากอะไรบ้าง</h2>
			<p>
				การประเมินราคาคอมพิวเตอร์ตั้งโต๊ะไม่ใช่แค่ดูยี่ห้อหรือปีที่ซื้อ แต่ต้องวิเคราะห์แต่ละชิ้นส่วนอย่างละเอียด
				เพื่อให้ได้ราคาที่สะท้อนมูลค่าจริงของเครื่อง ต่อไปนี้คือชิ้นส่วนหลักที่เราดูและวิธีคิดราคาโดยรวม
			</p>

			<h3>ซีพียู (CPU) — หัวใจของเครื่อง</h3>
			<p>
				ซีพียูเป็นชิ้นส่วนที่กำหนดราคาเครื่องมากที่สุดชิ้นหนึ่ง เราดูทั้งยี่ห้อ (Intel หรือ AMD) รุ่น
				เจเนอเรชัน จำนวนคอร์ ความเร็วสัญญาณนาฬิกา และ TDP
				ซีพียูรุ่นใหม่ที่ยังเป็นที่ต้องการในตลาดจะได้ราคาสูงกว่าอย่างชัดเจน
				ตัวอย่างเช่น Intel Core i7 เจน 12 ขึ้นไป หรือ AMD Ryzen 7 ซีรีส์ 5000 ขึ้นไป
				มักได้ราคาดีเพราะยังรองรับงานหนักได้สบาย
			</p>

			<h4>ซีพียูรุ่นเก่ายังมีค่าไหม</h4>
			<p>
				แม้จะเป็นซีพียูรุ่นเก่า เช่น Intel Core i5 เจน 6 หรือ AMD Ryzen 5 1600
				ก็ยังมีมูลค่าในตลาดมือสอง เพราะผู้ใช้บางส่วนต้องการเครื่องราคาประหยัดสำหรับงานเบา ๆ
				อย่างเปิดเว็บ ดูวิดีโอ หรืองานเอกสาร ราคาจะไม่สูงเท่ารุ่นใหม่ แต่ก็ไม่ใช่ศูนย์
				ดังนั้นอย่าเพิ่งทิ้งคอมเก่า ส่งสเปกมาให้เราดูก่อนได้เสมอ
			</p>

			<h3>แรม (RAM) — ยิ่งเยอะยิ่งมีค่า</h3>
