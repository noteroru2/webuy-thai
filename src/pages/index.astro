---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { fetchPosts, isWordpressConfigured } from '../lib/wordpress';
import { getSiteOrigin } from '../lib/site';

const configured = isWordpressConfigured();
const allPosts = configured ? await fetchPosts() : [];
const recent = allPosts.slice(0, 10);
const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'WE BUY | เรารับซื้อ';
const orgLogo = import.meta.env.PUBLIC_ORG_LOGO_URL ?? '/favicon.svg';
const socialRaw = import.meta.env.PUBLIC_ORG_SAME_AS ?? '';
const socialLinks = socialRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);
const businessPhone = import.meta.env.PUBLIC_BUSINESS_PHONE ?? '+66-64-257-9353';
const serviceAreasRaw =
	import.meta.env.PUBLIC_SERVICE_AREAS ??
	'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี,มหาสารคาม,สุรินทร์';
const serviceAreas = serviceAreasRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);
const mapUrl =
	import.meta.env.PUBLIC_GOOGLE_MAP_URL ??
	'https://maps.google.com/?q=13.7563,100.5018';
const techPillars = [
	{
		title: 'ประเมินรวดเร็ว',
		text: 'ส่งรูปและรายละเอียดทางไลน์ ทีมงานช่วยตีราคาเบื้องต้นได้ภายในไม่กี่ชั่วโมง',
	},
	{
		title: 'โปร่งใส ตรวจสอบได้',
		text: 'สื่อสารชัดเจนทุกขั้นตอน มีหลักฐานการคุยและข้อตกลงราคา',
	},
	{
		title: 'ติดต่อได้ 24 ชม.',
		text: 'แอดไลน์ @WEBUY ได้ตลอดเวลา เหมาะกับผู้ที่สะดวกทักดึกหรือวันหยุด',
	},
	{
		title: 'บทความประกอบการตัดสินใจ',
		text: 'อ่านคู่มือและเทคนิคก่อนขาย ลดความเสี่ยงและได้ราคาที่สมเหตุสมผล',
	},
];

const faqItems = [
	{
		question: 'รับประเมินราคาสินค้าอย่างไร?',
		answer:
			'ส่งรูปสินค้า รุ่น อุปกรณ์ที่มี และสภาพการใช้งานผ่าน Line @webuy ทีมงานจะประเมินราคาเบื้องต้นให้โดยเร็ว',
	},
	{
		question: 'ติดต่อช่วงเวลาไหนได้บ้าง?',
		answer: 'สามารถติดต่อผ่าน Line @webuy ได้ตลอด 24 ชั่วโมง',
	},
	{
		question: 'อยู่ต่างจังหวัดใช้บริการได้ไหม?',
		answer:
			'ได้ มีทีมงานให้คำแนะนำขั้นตอนและนัดหมายตามพื้นที่ที่ให้บริการ เพื่อความสะดวกของลูกค้า',
	},
	{
		question: 'ต้องเตรียมอะไรบ้างก่อนขาย?',
		answer:
			'เตรียมข้อมูลรุ่นสินค้า อุปกรณ์ที่มี ใบเสร็จหรือกล่อง (ถ้ามี) และแจ้งตำหนิการใช้งานเพื่อประเมินราคาได้แม่นยำขึ้น',
	},
];

const homeJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: orgName,
		url: site,
		inLanguage: 'th-TH',
		description:
			'เรารับซื้อ.com — รับซื้อโน๊ตบุ๊ค คอม ไอโฟน กล้อง และไอทีมือสอง ประเมินราคาโปร่งใส จ่ายเงินทันที แอดไลน์ @WEBUY',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: orgName,
		url: site,
		logo: new URL(orgLogo, site).toString(),
		sameAs: socialLinks.length > 0 ? socialLinks : undefined,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'LocalBusiness',
		name: orgName,
		url: site,
		logo: new URL(orgLogo, site).toString(),
		image: [new URL('/hero-soft.svg', site).toString()],
		description:
			'WE BUY | เรารับซื้อ รับซื้อและประเมินสินค้าไอทีมือสอง นัดรับถึงที่หรือจัดส่งได้ ติดต่อ Line @webuy',
		telephone: businessPhone,
		priceRange: '$$',
		areaServed: serviceAreas.map((area) => ({
			'@type': 'AdministrativeArea',
			name: area,
		})),
		openingHoursSpecification: [
			{
				'@type': 'OpeningHoursSpecification',
				dayOfWeek: [
					'Monday',
					'Tuesday',
					'Wednesday',
					'Thursday',
					'Friday',
					'Saturday',
					'Sunday',
				],
				opens: '00:00',
				closes: '23:59',
			},
		],
		contactPoint: [
			{
				'@type': 'ContactPoint',
				contactType: 'customer support',
				availableLanguage: ['Thai'],
				url: 'https://line.me/R/ti/p/@webuy',
				telephone: businessPhone,
			},
		],
		hasMap: mapUrl,
		sameAs: socialLinks.length > 0 ? socialLinks : undefined,
	},
];
---

<BaseLayout
	title="เรารับซื้อ.com | รับซื้อโน๊ตบุ๊ค คอม ไอโฟน กล้อง — WE BUY"
	description="อยากขายสินค้าไอทีมือสอง นึกถึงเรา เรารับซื้อ.com — รับซื้อโน๊ตบุ๊ค คอมพิวเตอร์ ไอโฟน ไอแพด มือถือ กล้อง ลำโพง และอื่น ๆ แอดไลน์ @WEBUY โทร 064-2579353"
	pathname="/"
	jsonLd={homeJsonLd}
>
	<section class="hero-wrap" aria-label="แบนเนอร์หน้าแรก">
		<div class="hero-stage">
			<div class="hero-stage-bg" aria-hidden="true"></div>
			<button
				type="button"
				class="hero-arrow hero-arrow--prev"
				disabled
				aria-hidden="true"
				tabindex="-1"
				title="สไลด์ก่อนหน้า (เร็ว ๆ นี้)"
			>
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</button>
			<button
				type="button"
				class="hero-arrow hero-arrow--next"
				disabled
				aria-hidden="true"
				tabindex="-1"
				title="สไลด์ถัดไป (เร็ว ๆ นี้)"
			>
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</button>
			<div class="container hero">
				<div class="hero-copy">
					<p class="eyebrow tech-eyebrow tech-eyebrow--dark">WE BUY · เรารับซื้อ.com</p>
					<h1 class="headline">รับซื้อโน๊ตบุ๊ค คอมพิวเตอร์ ไอโฟน และไอทีมือสอง — ให้ราคาดี ไม่กดราคา</h1>
					<p class="lede">
						ต้องการขายของมือสองให้นึกถึงเรา ส่งรูปและรายละเอียดทางไลน์ ทีมงานตีราคาให้รวดเร็ว ทั้งนัดเข้าร้านหรือให้ไปรับถึงที่ก็ได้
						จ่ายเงินทันทีเมื่อตกลงซื้อขาย
					</p>
					<div class="hero-actions">
						<a class="primary-btn" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">
							เริ่มประเมินผ่าน LINE
						</a>
						<a class="ghost-btn" href="/contact/">ดูข้อมูลติดต่อทั้งหมด</a>
					</div>
				</div>
				<aside class="contact-card" aria-label="ช่องทางติดต่อหลัก">
					<p class="contact-label">ติดต่อด่วน</p>
					<p class="contact-value">
						Line: <a href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">@webuy</a>
					</p>
					<p class="contact-note">แนะนำติดต่อผ่านไลน์เพื่อรับการประเมินเบื้องต้นที่รวดเร็วที่สุด</p>
					<a class="contact-btn" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">
						แชท LINE ตอนนี้
					</a>
				</aside>
				{
					!configured && (
						<div class="callout" role="status">
							<strong>ยังไม่ได้ตั้งค่า WordPress</strong>
							<p>
								คัดลอก <code>.env.example</code> เป็น <code>.env</code> แล้วใส่ URL
								ของ WordPress (เช่น <code>https://your-site.com</code>)
							</p>
						</div>
					)
				}
			</div>
			<div class="hero-dots" role="tablist" aria-label="ตำแหน่งสไลด์">
				<button type="button" class="hero-dot is-active" role="tab" aria-selected="true" aria-label="สไลด์ 1"></button>
				<button type="button" class="hero-dot" role="tab" aria-selected="false" aria-label="สไลด์ 2"></button>
				<button type="button" class="hero-dot" role="tab" aria-selected="false" aria-label="สไลด์ 3"></button>
			</div>
		</div>
	</section>
	<section class="container partner-strip" aria-label="ลูกค้าและพาร์ทเนอร์">
		<p class="partner-title tech-eyebrow">ได้รับความไว้วางใจจากลูกค้าและพาร์ทเนอร์ในหลายอุตสาหกรรม</p>
		<div class="partner-logos">
			<span>Tech Retail</span>
			<span>Digital Warehouse</span>
			<span>SME Commerce</span>
			<span>Enterprise IT</span>
			<span>Device Finance</span>
			<span>Service Network</span>
		</div>
	</section>
	<section class="container trust-band" aria-labelledby="trust-heading">
		<h2 id="trust-heading" class="section-title tech-h2">ทำไมถึงไว้ใจให้เราประเมินราคา</h2>
		<div class="trust-grid">
			{techPillars.map((pillar) => (
				<article class="trust-item">
					<h3>{pillar.title}</h3>
					<p>{pillar.text}</p>
				</article>
			))}
		</div>
	</section>
	<section class="container feature-split" aria-labelledby="feature-heading">
		<div class="feature-left">
			<p class="chip">บริการมืออาชีพ</p>
			<h2 id="feature-heading" class="tech-h2">กระบวนการชัดเจน ลดความกังวลเวลาขายของมือสอง</h2>
			<p class="lede">
				ตั้งแต่การรับข้อมูลสินค้า การประเมินราคา ไปจนถึงการยืนยันขั้นตอนติดต่อ เราออกแบบให้ชัดเจน
				เหมือนระบบงานที่ตรวจสอบได้ ช่วยลดความกังวลและเพิ่มความมั่นใจในการตัดสินใจ
			</p>
			<ul class="trust-list" aria-label="จุดเด่นบริการ tech">
				<li>ประเมินราคาโปร่งใสตามสภาพจริง</li>
				<li>ทีมงานตอบไวและนัดรับได้หลายพื้นที่</li>
				<li>มีบทความและข้อมูลประกอบการตัดสินใจ</li>
			</ul>
		</div>
		<div class="feature-right">
			<img
				class="hero-visual"
				src="/hero-soft.svg"
				alt="บริการรับซื้อสินค้าไอทีอย่างมืออาชีพ"
				width="920"
				height="360"
				loading="lazy"
			/>
		</div>
	</section>
	<section class="container feature-grid-2x2" aria-labelledby="feature-grid-heading">
		<h2 id="feature-grid-heading" class="section-title tech-h2">
			ระบบงานที่ออกแบบมาเพื่อป้องกันความเสี่ยงในการซื้อขาย
		</h2>
		<div class="big-grid">
			<article class="big-card">
				<p class="big-kicker">AUTHENTICATED</p>
				<h3>Revenue & Brand Protection</h3>
				<p>ลดความเสี่ยงจากข้อมูลไม่ครบหรือการตีราคาคลาดเคลื่อน ด้วยการตรวจสอบทีละขั้นตอน</p>
			</article>
			<article class="big-card dark">
				<p class="big-kicker">TRACEABILITY</p>
				<h3>ทุกดีลมีร่องรอยการสื่อสาร</h3>
				<p>สามารถย้อนดูรายละเอียดการประเมิน เงื่อนไข และหลักฐานการคุย เพื่อความโปร่งใส</p>
			</article>
			<article class="big-card">
				<p class="big-kicker">OPERATION LAYER</p>
				<h3>Workflow ที่ขยายต่อได้</h3>
				<p>รองรับการจัดการหลายพื้นที่ หลายประเภทสินค้า และการประเมินที่เป็นระบบเดียวกัน</p>
			</article>
			<article class="big-card">
				<p class="big-kicker">CUSTOMER CONFIDENCE</p>
				<h3>ข้อมูลพร้อมก่อนตัดสินใจ</h3>
				<p>มีบทความจริง, FAQ, และช่องทางติดต่อชัดเจน ช่วยให้ลูกค้าเชื่อถือและตัดสินใจเร็วขึ้น</p>
			</article>
		</div>
	</section>
	<section class="container services-section" aria-labelledby="services-heading">
		<h2 id="services-heading" class="section-title tech-h2">บริการรับซื้อสินค้าไอทีของเรา</h2>
		<p class="services-intro">
			เรารับซื้อสินค้าไอทีหลากหลายประเภท เลือกดูหมวดด้านล่าง หรือเข้า
			<a href="/รับซื้อ/">หน้ารวมรับซื้อ</a> เพื่อดูทุกหมวด
		</p>
		<div class="services-grid">
			<a href="/รับซื้อโน๊ตบุ๊ค/" class="service-card">
				<svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true"><rect x="4" y="8" width="28" height="18" rx="3" stroke="#ff8c00" stroke-width="2"/><path d="M2 26h32" stroke="#ff8c00" stroke-width="2" stroke-linecap="round"/></svg>
				<h3>รับซื้อโน๊ตบุ๊ค</h3>
				<p>MacBook, Dell, HP, Lenovo, ASUS, Acer, MSI ทุกรุ่นทั้งสายทำงานและเกมมิง</p>
			</a>
			<a href="/รับซื้อคอม/" class="service-card">
				<svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true"><rect x="8" y="4" width="20" height="20" rx="3" stroke="#ff8c00" stroke-width="2"/><path d="M14 24v6m8-6v6m-10 0h12" stroke="#ff8c00" stroke-width="2" stroke-linecap="round"/></svg>
				<h3>รับซื้อคอม</h3>
				<p>PC ประกอบ, คอมสำนักงาน, Gaming PC, Workstation, เซิร์ฟเวอร์ พร้อมอุปกรณ์ต่อพ่วง</p>
			</a>
			<a href="/รับซื้อไอโฟน/" class="service-card">
				<svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true"><rect x="10" y="3" width="16" height="30" rx="4" stroke="#ff8c00" stroke-width="2"/><circle cx="18" cy="28" r="1.5" fill="#ff8c00"/></svg>
				<h3>รับซื้อไอโฟน</h3>
				<p>iPhone ทุกรุ่นตั้งแต่ iPhone 8 ถึง iPhone 16 Pro Max ทั้งเครื่องไทยและเครื่องนอก</p>
			</a>
			<a href="/รับซื้อกล้อง/" class="service-card">
				<svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true"><rect x="4" y="8" width="28" height="20" rx="4" stroke="#ff8c00" stroke-width="2"/><circle cx="18" cy="18" r="6" stroke="#ff8c00" stroke-width="2"/><circle cx="18" cy="18" r="2" fill="#ff8c00"/></svg>
				<h3>รับซื้อกล้อง</h3>
				<p>DSLR, Mirrorless, Compact, Action Cam ทุกยี่ห้อ Canon, Nikon, Sony, Fujifilm พร้อมเลนส์</p>
			</a>
		</div>
	</section>
	<section class="container confidence" aria-labelledby="confidence-heading">
		<h2 id="confidence-heading" class="section-title tech-h2">ทำไมลูกค้าถึงเลือก WE BUY | เรารับซื้อ</h2>
		<div class="confidence-grid">
			<article class="confidence-item">
				<h3>ประเมินชัดเจน</h3>
				<p>ตรวจสอบสภาพและแจ้งช่วงราคาอย่างตรงไปตรงมา ไม่มีเงื่อนไขซ่อนเร้น</p>
			</article>
			<article class="confidence-item">
				<h3>ขั้นตอนรวดเร็ว</h3>
				<p>ส่งรายละเอียดผ่าน LINE แล้วรับคำแนะนำและขั้นตอนต่อไปได้ทันที</p>
			</article>
			<article class="confidence-item">
				<h3>สื่อสารได้ตลอด</h3>
				<p>มีช่องทางติดต่อชัดเจน ติดตามสถานะได้ และมีทีมงานตอบกลับต่อเนื่อง</p>
			</article>
		</div>
	</section>
	<section class="container authority" aria-labelledby="authority-heading">
		<h2 id="authority-heading" class="section-title tech-h2">มาตรฐานความน่าเชื่อถือของเรา</h2>
		<div class="authority-grid">
			<article class="authority-item">
				<p class="authority-number">24 ชั่วโมง</p>
				<p class="authority-label">ทีมงานตอบผ่าน LINE ต่อเนื่อง</p>
			</article>
			<article class="authority-item">
				<p class="authority-number">{allPosts.length}+</p>
				<p class="authority-label">บทความให้ความรู้และอัปเดตราคา</p>
			</article>
			<article class="authority-item">
				<p class="authority-number">{serviceAreas.length}+ พื้นที่</p>
				<p class="authority-label">ครอบคลุมการให้บริการหลายจังหวัด</p>
