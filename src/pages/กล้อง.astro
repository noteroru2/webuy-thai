---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBox from '../components/ContactBox.astro';
import '../styles/longform.css';
import { getSiteOrigin } from '../lib/site';

const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'WE BUY | เรารับซื้อ';
const serviceAreasRaw =
	import.meta.env.PUBLIC_SERVICE_AREAS ??
	'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี,มหาสารคาม,สุรินทร์';
const serviceAreas = serviceAreasRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);

const faqItems = [
	{ q: 'รับซื้อกล้องประเภทไหนบ้าง?', a: 'รับซื้อกล้อง DSLR, Mirrorless, Compact, Action Camera, กล้องฟิล์ม, เลนส์ทุกประเภท และอุปกรณ์เสริม เช่น แฟลช ขาตั้ง กิมบอล กระเป๋ากล้อง โดยประเมินจากรุ่น สภาพ และการทำงานจริง' },
	{ q: 'กล้องมีตำหนิเล็กน้อยขายได้ไหม?', a: 'ขายได้ เช่น รอยถลอกที่บอดี้ ยางกริปเสื่อม ฝุ่นภายนอก หรือชัตเตอร์สูง แต่ต้องแจ้งตามจริงเพื่อให้ประเมินราคาได้แม่นยำ กล้องที่มีปัญหาเซ็นเซอร์หรือบอร์ดเสียก็ยังรับประเมินได้เช่นกัน' },
	{ q: 'เลนส์มีราหรือฝ้าขายได้ไหม?', a: 'รับประเมินได้ แต่ราจะกระทบราคามากกว่าฝ้า เพราะราลุกลามได้และกระทบคุณภาพภาพถ่ายโดยตรง ฝ้าบางระดับอาจไม่มีผลต่อภาพเลย ทีมงานจะอธิบายเหตุผลราคาอย่างชัดเจน' },
	{ q: 'ต้องเตรียมอะไรบ้างก่อนขายกล้อง?', a: 'เตรียมตัวกล้อง เลนส์ แบตเตอรี่ ที่ชาร์จ สายคล้อง ฝาบอดี้ ฝาเลนส์ ฮูด ฟิลเตอร์ กล่องเดิม และใบเสร็จ (ถ้ามี) พร้อมถ่ายภาพสภาพทุกมุมและภาพทดสอบจากกล้อง' },
	{ q: 'ขายผ่านช่องทางไหนเร็วที่สุด?', a: 'แนะนำส่งรายละเอียดผ่าน Line @webuy เพราะแนบรูปและวิดีโอทดสอบได้สะดวก ทีมงานตอบกลับเร็วและประเมินได้ภายในไม่กี่ชั่วโมง หรือโทร 064-257-9353 เพื่อสอบถามเบื้องต้น' },
	{ q: 'รับซื้อกล้องฟิล์มไหม?', a: 'รับซื้อกล้องฟิล์มหลายประเภท ทั้ง SLR, Rangefinder, Point & Shoot และ Medium Format โดยเฉพาะรุ่นยอดนิยมอย่าง Nikon FM2, Canon AE-1, Olympus OM-1, Contax T2 รวมถึงเลนส์ Manual Focus ยุคเก่าที่ยังเป็นที่ต้องการของตลาด' },
	{ q: 'จำนวนชัตเตอร์มีผลต่อราคาแค่ไหน?', a: 'มีผลค่อนข้างมาก เพราะชัตเตอร์มีอายุการใช้งานจำกัด กล้องที่ชัตเตอร์ต่ำจะได้ราคาดีกว่า เช่น กล้อง Mirrorless ระดับกลางที่ชัตเตอร์ต่ำกว่า 30,000 ครั้งถือว่าน้อยมาก ส่วนกล้อง Pro ที่เกิน 200,000 ครั้งอาจต้องเผื่อค่าเปลี่ยนชัตเตอร์' },
	{ q: 'อยู่ต่างจังหวัดขายได้ไหม?', a: 'ได้ครับ รับประเมินออนไลน์ผ่าน Line @webuy สำหรับพื้นที่ให้บริการรับถึงที่ ครอบคลุมกรุงเทพฯ ปริมณฑล และจังหวัดหลักในภาคอีสาน สำหรับจังหวัดอื่นสามารถจัดส่งผ่านขนส่งได้ โดยทีมงานจะแนะนำวิธีแพ็กที่ปลอดภัย' },
	{ q: 'ใช้เวลาประเมินราคานานแค่ไหน?', a: 'หากส่งข้อมูลครบ (รุ่น, ชัตเตอร์, ภาพสภาพ, ภาพทดสอบ) ทีมงานมักตอบกลับช่วงราคาภายใน 1-3 ชั่วโมง ในกรณีที่ต้องตรวจสอบรุ่นหายากหรือกล้องฟิล์มเฉพาะทางอาจใช้เวลาเพิ่มเล็กน้อย' },
	{ q: 'GoPro หรือ Action Camera รับซื้อไหม?', a: 'รับซื้อครับ ทั้ง GoPro Hero ทุกรุ่น, DJI Action, Insta360 รวมถึงอุปกรณ์เสริมอย่างเคสกันน้ำ แบตเสริม และไม้เซลฟี่ โดยประเมินจากรุ่น สภาพเลนส์ สภาพหน้าจอ และการทำงานของระบบกันสั่น' },
];

const articleJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: 'รับซื้อกล้อง | รับซื้อกล้องมือสอง DSLR Mirrorless ทุกยี่ห้อ ราคาดี',
		description:
			'บริการรับซื้อกล้องมือสอง DSLR Mirrorless Compact กล้องฟิล์ม เลนส์ และอุปกรณ์เสริมทุกยี่ห้อ Canon Nikon Sony Fujifilm Panasonic Olympus Leica GoPro ประเมินราคาฟรี จ่ายเงินทันที',
		inLanguage: 'th-TH',
		author: { '@type': 'Organization', name: orgName },
		publisher: { '@type': 'Organization', name: orgName },
		mainEntityOfPage: `${site}/กล้อง/`,
		datePublished: '2026-03-24',
		dateModified: '2026-03-24',
		keywords:
			'รับซื้อกล้อง, ขายกล้องมือสอง, รับซื้อกล้องดิจิตอล, รับซื้อกล้อง DSLR, รับซื้อกล้อง Mirrorless, รับซื้อเลนส์, รับซื้อกล้องฟิล์ม, รับซื้อ Canon, รับซื้อ Nikon, รับซื้อ Sony, รับซื้อ Fujifilm, รับซื้อ GoPro, ขายกล้องราคาดี, ประเมินราคากล้อง',
		image: [new URL('/og-default.png', site).toString()],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
			{ '@type': 'ListItem', position: 2, name: 'รับซื้อกล้อง', item: `${site}/กล้อง/` },
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.q,
			acceptedAnswer: { '@type': 'Answer', text: item.a },
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'บริการรับซื้อกล้อง',
		description:
			'บริการรับซื้อกล้องมือสอง DSLR Mirrorless Compact ทุกยี่ห้อ Canon Nikon Sony Fujifilm พร้อมเลนส์และอุปกรณ์เสริม ประเมินราคาโปร่งใส จ่ายเงินทันที',
		provider: { '@type': 'Organization', name: orgName },
		areaServed: serviceAreas.map((area) => ({ '@type': 'AdministrativeArea', name: area })),
		serviceType: 'รับซื้อกล้องมือสอง',
		url: `${site}/กล้อง/`,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'วิธีขายกล้องมือสองกับ WE BUY',
		description: 'ขั้นตอนง่าย ๆ ในการขายกล้องมือสองให้ได้ราคาดี',
		step: [
			{
				'@type': 'HowToStep',
				name: 'ส่งข้อมูลกล้อง',
				text: 'แอดไลน์ @webuy แล้วส่งรูปกล้อง เลนส์ รุ่น Shutter Count และสภาพ',
			},
			{
				'@type': 'HowToStep',
				name: 'รับราคาประเมิน',
				text: 'ทีมงานผู้เชี่ยวชาญตรวจสอบและแจ้งราคาประเมิน',
			},
			{
				'@type': 'HowToStep',
				name: 'ยืนยันและนัดรับ',
				text: 'ตกลงราคา นัดหมายจุดรับ-ส่ง หรือจัดส่ง',
			},
			{
				'@type': 'HowToStep',
				name: 'รับเงินทันที',
				text: 'ตรวจสอบอุปกรณ์จริงและรับเงินทันที',
			},
		],
	},
];
---

<BaseLayout
	title="รับซื้อกล้อง | รับซื้อกล้องมือสอง DSLR Mirrorless ทุกยี่ห้อ | WE BUY"
	description="WE BUY รับซื้อกล้องมือสอง DSLR Mirrorless Compact ทุกยี่ห้อ Canon Nikon Sony Fujifilm พร้อมเลนส์ ประเมินราคาโปร่งใส จ่ายเงินทันที ติดต่อ Line @webuy 24 ชม."
	pathname="/กล้อง/"
	type="article"
	jsonLd={articleJsonLd}
>
	<article class="container longform">
		<header>
			<p class="kicker">CAMERA BUYBACK GUIDE</p>
			<h1>รับซื้อกล้อง: บริการรับซื้อกล้องมือสอง DSLR Mirrorless กล้องฟิล์ม เลนส์ และอุปกรณ์เสริม ทุกยี่ห้อ ราคาดี ประเมินฟรี</h1>
			<p class="intro">
				ถ้าคุณมีกล้องที่ไม่ได้ใช้วางอยู่ในตู้ ไม่ว่าจะเป็นกล้อง DSLR ที่เคยใช้ถ่ายงานแต่งงาน กล้อง Mirrorless ที่ซื้อมาแล้วเปลี่ยนระบบ กล้อง Compact
				ที่หมดความจำเป็น หรือแม้แต่กล้องฟิล์มที่เก็บไว้นานจนลืม บทความนี้จะช่วยให้คุณเข้าใจทุกขั้นตอนของการขายกล้องมือสองอย่างละเอียด
				ตั้งแต่การประเมินราคาว่าดูจากอะไรบ้าง กล้องประเภทไหนที่เรารับซื้อ ยี่ห้อไหนบ้างที่มีมูลค่าในตลาดมือสอง ไปจนถึงเลนส์และอุปกรณ์เสริมที่ขายได้
				เราอยากให้คุณตัดสินใจจากข้อมูลจริง ไม่ต้องเดา ไม่ต้องกังวล แค่ส่งรายละเอียดมาให้ทีมงานประเมิน แล้วเราจะดูแลให้ตั้งแต่ต้นจนจบ
			</p>
		</header>

		<!-- ═══════════════════════════════════════════════════════ -->
		<!-- SECTION 1: ทำไมต้องขายกล้องกับเรา -->
		<!-- ═══════════════════════════════════════════════════════ -->
		<section>
			<h2>ทำไมต้องขายกล้องกับเรา</h2>
			<p>
				ตลาดกล้องมือสองในไทยมีผู้รับซื้อจำนวนมาก ทั้งร้านค้า เพจออนไลน์ และกลุ่มซื้อขายในโซเชียลมีเดีย แต่ปัญหาที่คนขายพบบ่อยคือการตั้งราคาที่ไม่มีมาตรฐาน
				บางที่ให้ราคาสูงเกินจริงเพื่อดึงดูดแล้วมาหักหน้างาน บางที่กดราคาโดยไม่อธิบายเหตุผล ทำให้เสียเวลาและเสียความรู้สึก สิ่งที่เราทำต่างออกไปคือ
				การประเมินราคาแบบโปร่งใสและอธิบายได้ทุกจุด เราบอกชัดเจนว่าราคาที่ให้มาดูจากปัจจัยอะไรบ้าง ถ้ามีจุดที่กระทบราคาเราจะแจ้งล่วงหน้าพร้อมเหตุผล
				เพื่อให้คุณตัดสินใจได้อย่างมั่นใจ
			</p>
			<h3>ข้อดีที่ผู้ขายจะได้รับจากบริการของเรา</h3>
			<ul>
				<li><strong>ประเมินราคาฟรี</strong> ไม่มีค่าใช้จ่ายในการตรวจสอบสภาพ ส่งรูปมาประเมินก่อนได้ทาง Line</li>
				<li><strong>ราคาโปร่งใส</strong> อธิบายเหตุผลทุกจุดที่มีผลต่อราคา ไม่กดราคาโดยไม่มีเหตุผล</li>
				<li><strong>จ่ายเงินทันที</strong> เมื่อตกลงราคาและตรวจสอบสภาพตรงกัน จ่ายเงินสดหรือโอนทันที</li>
				<li><strong>รับซื้อทุกสภาพ</strong> แม้มีตำหนิหรือต้องซ่อม ก็ยังรับประเมินได้</li>
				<li><strong>บริการ 24 ชั่วโมง</strong> ทักมาได้ทุกเวลา ไม่มีวันหยุด</li>
			</ul>
			<p>
				เรารู้ดีว่ากล้องไม่ใช่แค่อุปกรณ์ มันเป็นเครื่องมือที่มีคุณค่าทางความรู้สึกด้วย ดังนั้นการขายกล้องควรเป็นประสบการณ์ที่ดี ไม่ใช่เรื่องที่ต้องลุ้น
				ถ้าคุณมีกล้องอยากขาย แค่แอดไลน์
				<a class="inline-contact" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">@webuy</a>
				แล้วส่งรูปมาให้ดู ทีมงานพร้อมช่วยประเมินให้ทันที
			</p>
		</section>

		<ContactBox heading="มีกล้องอยากขาย?" text="ส่งรูปกล้อง เลนส์ อุปกรณ์เสริมมาให้ประเมินราคาได้เลย ไม่มีค่าใช้จ่าย ตอบกลับเร็ว" />

		<!-- ═══════════════════════════════════════════════════════ -->
		<!-- SECTION 2: เราประเมินราคากล้องจากอะไรบ้าง -->
		<!-- ═══════════════════════════════════════════════════════ -->
		<section>
			<h2>เราประเมินราคากล้องจากอะไรบ้าง — เกณฑ์ที่ใช้จริงทุกเครื่อง</h2>
			<p>
				การประเมินราคากล้องมือสองมีความซับซ้อนกว่าสินค้าอิเล็กทรอนิกส์ทั่วไป เพราะกล้องมีชิ้นส่วนกลไกที่สึกหรอตามการใช้งาน มีชิ้นเลนส์ที่อาจเกิดปัญหาจากสภาพแวดล้อม
				และมีระบบอิเล็กทรอนิกส์ที่ต้องทำงานสัมพันธ์กันทุกจุด ทีมงานของเราจึงใช้เกณฑ์การประเมินหลายด้านร่วมกัน เพื่อให้ราคาที่ได้สะท้อนมูลค่าจริงของตัวกล้องมากที่สุด
			</p>

			<h3>สภาพบอดี้ภายนอก</h3>
			<p>
				สภาพภายนอกของบอดี้เป็นสิ่งแรกที่ทีมงานจะตรวจ ได้แก่ รอยขีดข่วน รอยบุบ สภาพยางกริป ความสมบูรณ์ของปุ่มกดและวงแหวนหมุนต่าง ๆ สภาพฮอตชู
				ช่องเมมโมรีการ์ด ช่องแบตเตอรี่ และพอร์ตเชื่อมต่อ กล้องที่สภาพภายนอกสวยย่อมได้ราคาดีกว่า แต่รอยใช้งานปกติไม่ได้กระทบราคามากนัก
				สิ่งที่กระทบราคาแรงคือรอยกระแทกที่อาจบ่งบอกว่าเคยตกหล่น หรือยางกริปที่หลุดลอกมากจนต้องเปลี่ยน
			</p>

			<h3>สภาพเซ็นเซอร์</h3>
			<h4>การตรวจ Dead Pixel และ Hot Pixel</h4>
			<p>
				เซ็นเซอร์คือหัวใจของกล้องดิจิตอล เราจะตรวจสอบว่ามี dead pixel หรือ hot pixel ที่ผิดปกติหรือไม่ โดยถ่ายภาพปิดฝาที่ ISO สูงและ Long Exposure
				จุดสว่างที่เกิดขึ้นจะบอกสภาพเซ็นเซอร์ได้ชัดเจน นอกจากนี้ยังตรวจฝุ่นบนเซ็นเซอร์โดยถ่ายภาพพื้นสว่างที่รูรับแสงแคบ (f/16-f/22) เพื่อดูว่ามีจุดดำหรือเงาผิดปกติหรือไม่
			</p>
			<h4>สภาพ Low-pass Filter และ Coating</h4>
			<p>
				กล้องบางรุ่นมี Low-pass Filter หน้าเซ็นเซอร์ที่อาจมีรอยขีดข่วนจากการทำความสะอาดไม่ถูกวิธี รอยเหล่านี้จะปรากฏในภาพถ่ายเป็นเงาจาง ๆ
				ซึ่งกระทบคุณภาพภาพและราคาอย่างมีนัยสำคัญ
			</p>

			<h3>จำนวนชัตเตอร์ (Shutter Count)</h3>
			<p>
				ชัตเตอร์ของกล้องมีอายุการใช้งานจำกัด ขึ้นอยู่กับรุ่นและระดับ เช่น กล้องระดับเริ่มต้นมักมีอายุชัตเตอร์ประมาณ 100,000-150,000 ครั้ง
				กล้องระดับกลางประมาณ 150,000-200,000 ครั้ง และกล้องระดับโปรประมาณ 300,000-500,000 ครั้ง จำนวนชัตเตอร์ที่ต่ำหมายความว่ากล้องยังมีอายุการใช้งานเหลือมาก
				ราคาจึงดีกว่ากล้องที่ชัตเตอร์สูง สำหรับกล้อง Mirrorless ที่ใช้ Electronic Shutter เป็นหลัก จำนวน Mechanical Shutter จะสะท้อนการใช้งานจริงน้อยกว่า
				แต่ก็ยังเป็นตัวบ่งชี้อายุการใช้งานโดยรวมได้
			</p>

			<div class="highlight-box">
				<strong>เคล็ดลับ:</strong> ก่อนขายกล้อง ควรเช็กจำนวนชัตเตอร์ด้วยซอฟต์แวร์ที่เชื่อถือได้ เช่น ShutterCount สำหรับ Canon
				หรืออ่านจากข้อมูล EXIF ของไฟล์ภาพ สำหรับกล้อง Sony สามารถดูได้จากเมนู Settings หรือเว็บไซต์ตรวจ EXIF ออนไลน์
				การแจ้งจำนวนชัตเตอร์ตั้งแต่แรกจะช่วยให้ประเมินราคาได้เร็วและแม่นยำขึ้น
			</div>

			<h3>คุณภาพเลนส์</h3>
			<h4>ราและฝ้า (Fungus & Haze)</h4>
			<p>
				ราในเลนส์เป็นปัญหาที่พบบ่อยในเมืองไทยเนื่องจากสภาพอากาศชื้น ราจะปรากฏเป็นเส้นใยหรือจุดบนชิ้นเลนส์ ถ้าราอยู่ชั้นนอกที่ทำความสะอาดได้จะกระทบราคาน้อย
				แต่ถ้าราอยู่ชั้นในที่ต้องถอดเลนส์เพื่อล้าง หรือราที่กัดเคลือบเลนส์จนเกิดรอยถาวร จะกระทบราคาอย่างมาก ส่วนฝ้าคือความขุ่นมัวของชิ้นเลนส์ที่เกิดจากอายุการใช้งาน
				สารเคลือบเสื่อม หรือไอน้ำ ฝ้าบาง ๆ ที่ไม่มีผลต่อภาพถ่ายอาจไม่กระทบราคามาก แต่ฝ้าหนักที่ทำให้ภาพซอฟต์ขึ้นอย่างเห็นได้ชัดจะลดมูลค่าลงมาก
			</p>
			<h4>ฝุ่นภายในเลนส์</h4>
			<h5>ฝุ่นที่ไม่มีผลต่อภาพ vs ฝุ่นที่มีผล</h5>
			<p>
				เลนส์แทบทุกตัวมีฝุ่นภายในบ้าง ซึ่งเป็นเรื่องปกติและมักไม่มีผลต่อภาพถ่ายเลย โดยเฉพาะฝุ่นเล็ก ๆ ที่อยู่ห่างจากระนาบโฟกัส
				แต่ฝุ่นขนาดใหญ่หรือกลุ่มฝุ่นที่สะสมมากอาจทำให้เกิดจุดดำในภาพเมื่อปิดรูรับแสงแคบ ทีมงานจะตรวจและแจ้งว่าฝุ่นที่พบมีผลต่อภาพหรือไม่
			</p>
			<h4>ความแม่นยำของระบบออโต้โฟกัส</h4>
			<p>
				ระบบ AF ที่แม่นยำเป็นสิ่งสำคัญมาก โดยเฉพาะเลนส์ AF ราคาสูงอย่างเลนส์เทเลหรือเลนส์ไวแสง ถ้าเลนส์โฟกัสไม่ตรงจุดที่เลือก
				หรือมีอาการ front-focus / back-focus ก็จะกระทบราคา กล้องบางรุ่นสามารถปรับ AF Fine Tune ได้ แต่ถ้าเลนส์มีปัญหา AF Motor
				เช่น เสียงดังผิดปกติ โฟกัสช้าลงมาก หรือโฟกัสไม่ทำงานเลย จะถือเป็นจุดที่กระทบราคาอย่างมีนัยสำคัญ
			</p>

			<h3>ยี่ห้อและรุ่น (Brand & Model)</h3>
			<p>
				ยี่ห้อและรุ่นของกล้องมีผลต่อราคามือสองโดยตรง กล้องบางรุ่นเป็นที่ต้องการสูงในตลาดมือสองทำให้ราคาตกช้ากว่ารุ่นอื่น
				ในขณะที่กล้องบางรุ่นที่ถูกแทนที่ด้วยรุ่นใหม่ที่ดีกว่ามากจะราคาตกเร็ว ตัวอย่างเช่น กล้อง Sony A7 III ยังคงเป็นที่ต้องการมากแม้จะมีรุ่นใหม่ออกมาแล้ว
				ในขณะที่กล้อง DSLR ระดับเริ่มต้นบางรุ่นจะราคาตกเร็วกว่า นอกจากนี้กล้องรุ่นที่เลิกผลิตแล้วแต่มีความนิยมสูง
				เช่น Fujifilm X100V หรือ Nikon Df อาจมีราคามือสองที่สูงกว่าราคาตอนใหม่ด้วยซ้ำ
			</p>
		</section>

