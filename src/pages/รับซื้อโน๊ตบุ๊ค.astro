---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBox from '../components/ContactBox.astro';
import '../styles/longform.css';
import { getSiteOrigin } from '../lib/site';

const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'WE BUY | เรารับซื้อ';
const serviceAreasRaw =
	import.meta.env.PUBLIC_SERVICE_AREAS ??
	'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี,มหาสารคาม,สุรินทร์';
const serviceAreas = serviceAreasRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);

const faqItems = [
	{
		q: 'รับซื้อโน๊ตบุ๊คยี่ห้ออะไรบ้าง?',
		a: 'รับซื้อหลากหลายแบรนด์ ได้แก่ Apple MacBook, Dell, HP, Lenovo, ASUS, Acer, MSI, Razer, Samsung, Microsoft Surface, Huawei MateBook และอื่น ๆ ทั้งรุ่นสายทำงาน สายเรียน และสายเกมมิง โดยพิจารณาจากสเปกและสภาพเครื่องเป็นหลัก',
	},
	{
		q: 'โน๊ตบุ๊คมีตำหนิหรือแบตเสื่อมยังขายได้ไหม?',
		a: 'ขายได้ครับ ทีมงานจะประเมินตามสภาพจริง โดยดูผลกระทบต่อการใช้งานและต้นทุนซ่อมอย่างโปร่งใส แจ้งตำหนิตรง ๆ ตั้งแต่แรกจะช่วยให้ประเมินได้แม่นยำและปิดดีลเร็วขึ้น',
	},
	{
		q: 'ต้องล้างข้อมูลก่อนขายไหม?',
		a: 'ควรล้างข้อมูลและออกจากระบบบัญชีต่าง ๆ ก่อนส่งมอบ โดยเฉพาะ Apple ID, Microsoft Account, Google Account และระบบ cloud sync หากไม่สะดวก ทีมงานสามารถแนะนำขั้นตอนสำรองข้อมูลและรีเซ็ตระบบอย่างปลอดภัยได้',
	},
	{
		q: 'ติดต่อช่องทางไหนเร็วที่สุด?',
		a: 'แนะนำติดต่อผ่าน Line @webuy เพราะสามารถส่งรูป สเปก และวิดีโอเครื่องได้ทันที ทำให้ประเมินได้รวดเร็วและครบข้อมูล หรือโทร 064-257-9353 ก็ได้เช่นกัน',
	},
	{
		q: 'ประเมินราคาใช้เวลานานไหม?',
		a: 'หากส่งข้อมูลสเปก รูปเครื่อง และตำหนิมาครบตั้งแต่ครั้งแรก ทีมงานสามารถประเมินราคาเบื้องต้นได้ภายใน 15-30 นาทีในช่วงเวลาทำการ และตอบกลับภายในไม่เกิน 2 ชั่วโมงสำหรับช่วงนอกเวลา',
	},
	{
		q: 'จ่ายเงินอย่างไรหลังตกลงราคา?',
		a: 'จ่ายเงินสดทันทีหน้างาน หรือโอนเงินผ่านบัญชีธนาคารทันทีเมื่อตรวจรับเครื่องเสร็จ ทั้งนี้ขึ้นอยู่กับความสะดวกของลูกค้า โดยทุกธุรกรรมมีหลักฐานการชำระเงินชัดเจน',
	},
	{
		q: 'อยู่ต่างจังหวัดขายได้ไหม?',
		a: 'ขายได้ครับ สามารถส่งข้อมูลผ่าน Line @webuy แล้วจัดส่งเครื่องทางพัสดุ เมื่อตรวจรับเรียบร้อยจะโอนเงินให้ทันที โดยแนะนำให้ถ่ายวิดีโอตอนแพ็กเครื่องและบันทึกเลขพัสดุไว้เป็นหลักฐาน',
	},
	{
		q: 'MacBook ที่ยังผูก Apple ID อยู่ขายได้ไหม?',
		a: 'แนะนำให้ปลด Apple ID และปิด Find My Mac ก่อนขาย เพราะหากยังล็อกอยู่จะกระทบราคาอย่างมากและอาจไม่สามารถรับซื้อได้ หากไม่แน่ใจวิธีปลด สามารถสอบถามทีมงานได้เลย',
	},
	{
		q: 'โน๊ตบุ๊คเกมมิงกับโน๊ตบุ๊คทำงานราคาต่างกันอย่างไร?',
		a: 'โน๊ตบุ๊คเกมมิงที่มี GPU แยกมักได้ราคาสูงกว่าเพราะ demand ในตลาดมือสองสูง ส่วนโน๊ตบุ๊คทำงาน (business-class) อย่าง ThinkPad หรือ EliteBook ก็มีมูลค่าดีเพราะความทนทานและความน่าเชื่อถือ ราคาจริงขึ้นอยู่กับสเปก สภาพ และความต้องการของตลาดในช่วงนั้น',
	},
	{
		q: 'ให้บริการวันไหนบ้าง?',
		a: 'ให้บริการประเมินราคาทุกวัน ตลอด 24 ชั่วโมง ไม่มีวันหยุด สามารถส่งข้อมูลเข้ามาได้ทุกเวลาผ่าน Line @webuy หรือโทร 064-257-9353',
	},
];

const articleJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: 'รับซื้อโน๊ตบุ๊ค มือสอง ทุกยี่ห้อ ประเมินราคาฟรี จ่ายเงินทันที',
		description:
			'บทความเชิงลึกสำหรับผู้ที่ต้องการขายโน๊ตบุ๊คมือสอง ครอบคลุมการประเมินราคาตาม CPU RAM SSD GPU หน้าจอ แบต แบรนด์ การเตรียมเครื่อง และขั้นตอนขายอย่างปลอดภัย รับซื้อ MacBook Dell HP Lenovo ASUS Acer MSI ทั่วประเทศ',
		inLanguage: 'th-TH',
		author: { '@type': 'Organization', name: orgName },
		publisher: { '@type': 'Organization', name: orgName },
		mainEntityOfPage: `${site}/โน๊ตบุ๊ค/`,
		datePublished: '2026-03-24',
		dateModified: '2026-03-24',
		image: [new URL('/og-default.png', site).toString()],
		keywords:
			'รับซื้อโน๊ตบุ๊ค, ขายโน๊ตบุ๊คมือสอง, ประเมินราคาโน๊ตบุ๊ค, รับซื้อ laptop, รับซื้อ notebook, รับซื้อ MacBook, รับซื้อโน๊ตบุ๊คเกมมิง, ขายโน๊ตบุ๊คได้ราคาดี, รับซื้อโน๊ตบุ๊คถึงที่',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
			{ '@type': 'ListItem', position: 2, name: 'รับซื้อโน๊ตบุ๊ค', item: `${site}/โน๊ตบุ๊ค/` },
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.q,
			acceptedAnswer: { '@type': 'Answer', text: item.a },
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'บริการรับซื้อโน๊ตบุ๊คมือสอง',
		description:
			'บริการรับซื้อโน๊ตบุ๊คมือสองทุกยี่ห้อ ทุกรุ่น ประเมินราคาโปร่งใส จ่ายเงินทันที ติดต่อ Line @webuy ตลอด 24 ชั่วโมง',
		provider: { '@type': 'Organization', name: orgName },
		areaServed: serviceAreas.map((area) => ({ '@type': 'AdministrativeArea', name: area })),
		serviceType: 'รับซื้อโน๊ตบุ๊คมือสอง',
		url: `${site}/โน๊ตบุ๊ค/`,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'วิธีขายโน๊ตบุ๊คมือสองกับ WE BUY',
		description: 'ขั้นตอนง่าย ๆ ในการขายโน๊ตบุ๊คมือสองให้ได้ราคาดีกับ WE BUY',
		step: [
			{ '@type': 'HowToStep', name: 'ส่งข้อมูลเครื่อง', text: 'แอดไลน์ @webuy แล้วส่งรูปเครื่อง รุ่น สเปก และสภาพการใช้งาน' },
			{ '@type': 'HowToStep', name: 'รับราคาประเมิน', text: 'ทีมงานตรวจสอบและแจ้งราคาประเมินเบื้องต้นให้ภายในเวลาอันรวดเร็ว' },
			{ '@type': 'HowToStep', name: 'ยืนยันและนัดรับ', text: 'ตกลงราคา นัดหมายจุดรับ-ส่ง หรือจัดส่งทางขนส่ง' },
			{ '@type': 'HowToStep', name: 'รับเงินทันที', text: 'ตรวจสอบเครื่องจริงและรับเงินโอนหรือเงินสดทันที' },
		],
	},
];
---

<BaseLayout
	title="รับซื้อโน๊ตบุ๊ค | ประเมินราคาโน๊ตบุ๊คมือสอง ได้ราคาดี | WE BUY"
	description="WE BUY รับซื้อโน๊ตบุ๊คมือสองทุกยี่ห้อ MacBook Dell HP Lenovo ASUS Acer MSI ประเมินราคาฟรี จ่ายเงินสดทันที บริการ 24 ชม. ติดต่อ Line @webuy"
	pathname="/โน๊ตบุ๊ค/"
	type="article"
	jsonLd={articleJsonLd}
>
	<article class="container longform">

		<header class="article-head">
			<p class="kicker">Notebook Buyback Guide</p>
			<h1>รับซื้อโน๊ตบุ๊คมือสอง ทุกยี่ห้อ ทุกรุ่น ประเมินราคาฟรี จ่ายเงินทันที ติดต่อง่ายตลอด 24 ชั่วโมง</h1>
			<p class="intro">
				หากคุณกำลังคิดจะขายโน๊ตบุ๊คเครื่องเก่าแต่ยังไม่แน่ใจว่าจะเริ่มต้นอย่างไร ไม่รู้ว่าเครื่องของตัวเองจะได้ราคาเท่าไร
				หรือกังวลเรื่องความปลอดภัยของข้อมูลส่วนตัว บทความนี้เขียนขึ้นมาเพื่อคุณโดยเฉพาะ เราจะพาคุณเดินทางตั้งแต่ทำความเข้าใจว่าราคาโน๊ตบุ๊คมือสองถูกกำหนดจากอะไรบ้าง
				ไปจนถึงวิธีเตรียมเครื่อง การเลือกช่องทางขายที่ปลอดภัย และเคล็ดลับที่ช่วยให้คุณได้ราคาดีที่สุดเท่าที่จะเป็นไปได้
				เนื้อหาครอบคลุมทั้งโน๊ตบุ๊คทำงาน โน๊ตบุ๊คเกมมิง และโน๊ตบุ๊คระดับพรีเมียมอย่าง MacBook โดยเราให้บริการ<strong>รับซื้อโน๊ตบุ๊คทุกยี่ห้อ</strong>
				ทั่วประเทศ ติดต่อได้ตลอด 24 ชั่วโมง ไม่มีวันหยุด
			</p>
		</header>

		<!-- ═══════════════════════════════════════════════════════════ -->
		<section>
			<h2>
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px;color:var(--accent)"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
				ทำไมต้องขายโน๊ตบุ๊คกับเรา — เหตุผลที่คนเลือกใช้บริการ
			</h2>

			<h3>ประเมินราคาตรงไปตรงมา อิงสเปกจริง</h3>
			<p>
				ปัญหาที่คนขายโน๊ตบุ๊คมือสองเจอบ่อยที่สุดคือ "ไม่รู้ว่าราคาที่ได้ยุติธรรมหรือเปล่า" บางร้านให้ราคาต่ำมากโดยไม่อธิบายเหตุผล
				หรือบางร้านแจ้งราคาสูงทางแชทแต่พอเจอเครื่องจริงก็กดราคาลงมาก ทำให้เสียเวลาและเสียความรู้สึก
				ที่ WE BUY เราใช้ระบบประเมินที่อิงจากสเปกจริงของเครื่องเป็นหลัก ได้แก่ ซีพียู แรม สตอเรจ การ์ดจอ หน้าจอ แบตเตอรี่ และสภาพภายนอก
				ทุกรายการที่มีผลต่อราคาจะถูกอธิบายให้ลูกค้าเข้าใจอย่างชัดเจน ไม่มีการกดราคาแบบไม่มีเหตุผล
			</p>

			<h3>จ่ายเงินทันทีหลังตกลง ไม่ต้องรอ</h3>
			<p>
				เมื่อตรวจรับเครื่องเรียบร้อยและทั้งสองฝ่ายตกลงราคากันแล้ว เราจ่ายเงินสดทันทีหรือโอนเข้าบัญชีภายในไม่กี่นาที
				ไม่มีระบบพักเงิน ไม่มีเงื่อนไขซ่อนเร้น คุณได้รับเงินเต็มจำนวนตามที่ตกลงกัน นี่คือเหตุผลที่ลูกค้าจำนวนมากเลือกกลับมาใช้บริการซ้ำ
				เพราะความแน่นอนและความรวดเร็วเป็นสิ่งที่ทุกคนต้องการ หากคุณอยากเริ่มประเมินราคาตอนนี้
				สามารถทักมาได้ที่ <a class="inline-contact" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">Line @webuy</a>
				หรือโทร <a class="phone-link" href="tel:0642579353">064-257-9353</a> ได้เลยครับ
			</p>

			<h3>บริการ 24 ชั่วโมง ไม่มีวันหยุด</h3>
			<p>
				เราเข้าใจว่าหลายคนมีเวลาว่างหลังเลิกงานหรือช่วงดึก การเปิดให้บริการตลอด 24 ชั่วโมงจึงเป็นสิ่งที่เราตั้งใจทำ
				เพื่อให้ลูกค้าสามารถส่งข้อมูลเครื่องเข้ามาได้ทุกเวลาที่สะดวก ไม่ต้องรอจนถึงเช้าวันจันทร์
				ทีมงานจะตอบกลับเร็วที่สุดเท่าที่จะทำได้ และหากส่งข้อมูลครบถ้วนมาตั้งแต่ครั้งแรก การประเมินจะเร็วขึ้นอีกมาก
			</p>
		</section>

		<ContactBox
			heading="อยากขายโน๊ตบุ๊ค? เริ่มต้นง่าย ๆ ตรงนี้เลย"
			text="ส่งรูปเครื่อง รุ่น สเปก และสภาพมาได้เลย ทีมงานประเมินราคาให้ฟรี ไม่มีค่าใช้จ่าย"
			variant="primary"
		/>

		<!-- ═══════════════════════════════════════════════════════════ -->
		<section>
			<h2>
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px;color:var(--accent)"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
				ปัจจัยที่กำหนดราคาโน๊ตบุ๊คมือสอง — เราประเมินจากอะไรบ้าง
			</h2>

			<p>
				หลายคนสงสัยว่าทำไมโน๊ตบุ๊ครุ่นเดียวกันแต่ราคารับซื้อต่างกัน คำตอบคือราคาไม่ได้ขึ้นอยู่กับชื่อรุ่นเพียงอย่างเดียว
				แต่เป็นผลรวมของหลายองค์ประกอบที่ทำงานร่วมกัน ด้านล่างนี้คือปัจจัยหลักที่เราใช้ในการประเมินราคา
			</p>

			<h3>ซีพียู (CPU) — หัวใจของประสิทธิภาพ</h3>
			<p>
				ซีพียูเป็นชิ้นส่วนที่มีผลต่อราคามากที่สุดอย่างหนึ่ง เพราะเป็นตัวกำหนดความเร็วในการประมวลผลหลักของเครื่อง
				โน๊ตบุ๊คที่ใช้ Intel Core i7 หรือ i9 เจเนอเรชันใหม่ ๆ จะได้ราคาดีกว่า Core i3 หรือ i5 รุ่นเก่าอย่างชัดเจน
				เช่นเดียวกับฝั่ง AMD ที่ Ryzen 7 หรือ Ryzen 9 จะมีมูลค่าสูงกว่า Ryzen 3 หรือ Ryzen 5 รุ่นเริ่มต้น
				สำหรับ Apple MacBook ที่ใช้ชิป M1 Pro, M2 Max หรือ M3 จะได้ราคาสูงตามประสิทธิภาพที่เหนือกว่า M1 ธรรมดา
				สิ่งสำคัญคือต้องรู้รุ่นซีพียูที่แน่นอน ไม่ใช่แค่ "Intel Core i7" เพราะ i7 เจน 8 กับ i7 เจน 13 ราคาต่างกันหลายพันบาท
			</p>

			<h4>วิธีเช็กรุ่น CPU บน Windows</h4>
			<p>
				กดปุ่ม Windows + R พิมพ์ <code>msinfo32</code> แล้ว Enter จะเห็นรายละเอียดซีพียูเต็ม ๆ
				หรือคลิกขวาที่ This PC เลือก Properties ก็จะเห็นชื่อรุ่นเช่นกัน
			</p>
			<h4>วิธีเช็กรุ่นบน Mac</h4>
			<p>
				คลิกเมนู Apple ที่มุมซ้ายบน เลือก About This Mac จะแสดงชิปหรือรุ่นโปรเซสเซอร์ให้เลย
				ถ่ายหน้าจอตรงนี้ส่งมาให้ทีมงานจะช่วยให้ประเมินได้เร็วมาก
			</p>

			<h3>แรม (RAM) — ยิ่งมากยิ่งดี</h3>
			<p>
				แรมมีผลต่อความลื่นไหลในการใช้งานหลายโปรแกรมพร้อมกัน โน๊ตบุ๊คที่มีแรม 16GB หรือ 32GB จะได้ราคาสูงกว่า 8GB อย่างเห็นได้ชัด
				โดยเฉพาะในยุคที่ซอฟต์แวร์ส่วนใหญ่กินแรมมากขึ้นเรื่อย ๆ เครื่องที่แรม 8GB เริ่มเป็นขั้นต่ำสำหรับงานทั่วไปแล้ว
				ถ้าเครื่องของคุณมีแรม 4GB ราคาจะลดลงมากเพราะต้นทุนอัปเกรดสูงและบางรุ่นอัปเกรดไม่ได้เลย
				โน๊ตบุ๊คบางรุ่นจะบัดกรีแรมติดบอร์ด ทำให้ไม่สามารถเพิ่มได้ในภายหลัง จุดนี้มีผลต่อราคาเช่นกัน
			</p>

			<h3>สตอเรจ (SSD / HDD) — ความเร็วและความจุ</h3>
			<p>
				โน๊ตบุ๊คที่ใช้ SSD NVMe จะได้ราคาสูงกว่า SATA SSD หรือ HDD แบบเก่า เพราะความเร็วในการอ่านเขียนข้อมูลต่างกันหลายเท่า
				ความจุก็มีผล โดย 512GB ขึ้นไปมักได้ราคาดี ส่วน 256GB ยังพอรับได้ แต่ 128GB เริ่มน้อยเกินไปสำหรับการใช้งานทั่วไปในปัจจุบัน
				เครื่องที่ยังใช้ HDD อย่างเดียวมักได้ราคาต่ำเพราะต้นทุนอัปเกรดเป็น SSD ค่อนข้างชัดเจน
			</p>

			<h3>การ์ดจอ (GPU) — ตัวตัดสินราคาสายเกมมิง</h3>
			<p>
				สำหรับโน๊ตบุ๊คเกมมิงหรือโน๊ตบุ๊คสำหรับงานกราฟิก การ์ดจอเป็นปัจจัยที่มีน้ำหนักสูงมาก
				เครื่องที่มี NVIDIA RTX 3060, RTX 4070 หรือสูงกว่าจะได้ราคาดีอย่างเห็นได้ชัด ในขณะที่เครื่องที่ใช้ GPU ออนบอร์ดอย่าง Intel UHD
				หรือ Intel Iris Xe จะถูกประเมินในหมวดโน๊ตบุ๊คทำงานทั่วไปซึ่งราคาจะต่ำกว่าเกมมิง
				จุดที่ต้องระวังคือบางรุ่นมี GPU สองตัว (hybrid graphics) ซึ่งต้องระบุรุ่น GPU ที่แน่นอนมาด้วยจึงจะประเมินได้แม่น
			</p>

			<h3>หน้าจอ — ความละเอียดและคุณภาพแผง</h3>
			<h5>ปัจจัยเรื่องหน้าจอที่มีผลต่อราคา</h5>
			<p>
				หน้าจอ Full HD (1920x1080) เป็นมาตรฐานขั้นต่ำที่ไม่กระทบราคา แต่ถ้าเป็น 2K, 4K, OLED หรือ Mini-LED จะช่วยเพิ่มมูลค่าได้
				ในขณะเดียวกัน หน้าจอที่มี dead pixel, backlight bleed รุนแรง หรือรอยแตกจะกระทบราคาอย่างมาก
				ขนาดหน้าจอก็มีผล โดย 14-15.6 นิ้วเป็นขนาดที่ตลาดต้องการมากที่สุด ส่วน 13 นิ้วเน้นกลุ่มพกพา และ 17 นิ้วเน้นกลุ่มเกมมิง
			</p>

			<h3>แบตเตอรี่ — สุขภาพแบตมีค่ามากกว่าที่คิด</h3>
			<p>
				แบตเตอรี่ที่เสื่อมคือหนึ่งในสาเหตุหลักที่ทำให้ราคาลดลง เพราะค่าเปลี่ยนแบตใหม่ไม่ถูก โดยเฉพาะ MacBook ที่ต้องเปลี่ยนทั้งชุด
				โน๊ตบุ๊คที่แบตยังมี cycle count ต่ำหรือ health สูงกว่า 80% จะได้ราคาดีกว่าเครื่องที่แบตเกือบหมดอายุ
				แนะนำให้ถ่ายหน้าจอผล battery health มาประกอบเมื่อประเมินราคา จะช่วยให้ทีมงานให้ราคาได้แม่นยำขึ้น
			</p>

			<h5>วิธีเช็ก battery health</h5>
			<p>
				บน Windows ให้เปิด Command Prompt แล้วพิมพ์ <code>powercfg /batteryreport</code> จะได้ไฟล์ HTML ที่แสดง design capacity กับ full charge capacity
				บน Mac ให้กด Option แล้วคลิกเมนู Apple เลือก System Information ดูที่หัวข้อ Power จะเห็น cycle count และ condition
			</p>

			<h3>แบรนด์และรุ่น — ชื่อเสียงมีผลต่อราคามือสอง</h3>
			<p>
				แบรนด์ที่มีชื่อเสียงในตลาดมือสองมักจะได้ราคาดีกว่า เพราะผู้ซื้อมือสองมีความมั่นใจในคุณภาพและอะไหล่หาง่ายกว่า
				Apple MacBook เป็นแบรนด์ที่ราคาตกน้อยที่สุดเพราะ demand สูงตลอด Lenovo ThinkPad กับ Dell Latitude ก็เป็นที่นิยมในกลุ่มธุรกิจ
				ส่วน ASUS ROG, MSI และ Acer Predator ก็แข็งแกร่งในกลุ่มเกมมิง HP Spectre, Dell XPS และ ASUS ZenBook เป็นที่ต้องการในกลุ่มพรีเมียม
			</p>

			<div class="highlight-box">
				<strong>เคล็ดลับ:</strong> ยิ่งส่งข้อมูลสเปกครบเท่าไร ราคาประเมินยิ่งแม่นยำขึ้นเท่านั้น
				แนะนำถ่ายภาพหน้าจอสเปกจาก System Information หรือ msinfo32 แล้วส่งมาให้ทีมงานพร้อมกับรูปเครื่อง
			</div>
		</section>

