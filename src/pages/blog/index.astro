---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { fetchPosts, isWordpressConfigured } from '../../lib/wordpress';
import { getSiteOrigin } from '../../lib/site';

const configured = isWordpressConfigured();
const posts = configured ? await fetchPosts() : [];
const site = getSiteOrigin();
const listJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: 'บทความ | เรารับซื้อ.com',
		description: 'รวมบทความรับซื้อโน๊ตบุ๊ค คอม ไอโฟน และไอทีมือสอง จาก WE BUY | เรารับซื้อ',
		url: `${site}/blog/`,
		inLanguage: 'th-TH',
		mainEntity: {
			'@type': 'ItemList',
			numberOfItems: posts.length,
			itemListElement: posts.slice(0, 50).map((post, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				url: `${site}/${post.slug}/`,
				name: post.title.rendered.replace(/<[^>]+>/g, '').trim(),
			})),
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
			{ '@type': 'ListItem', position: 2, name: 'บทความ', item: `${site}/blog/` },
		],
	},
];
---

<BaseLayout
	title="บทความ | เรารับซื้อ.com"
	description="บทความรับซื้อสินค้าไอทีมือสอง ประเมินราคา เตรียมเครื่องก่อนขาย — WE BUY | เรารับซื้อ"
	pathname="/blog/"
	jsonLd={listJsonLd}
>
	<div class="container page-head">
		<p class="tech-eyebrow">Knowledge base · WordPress</p>
		<h1 class="page-title tech-h2">บทความ</h1>
		<p class="intro">บทความจาก WordPress ดึงมาแสดงที่นี่ — อ่านก่อนตัดสินใจขาย แล้วแอดไลน์ @webuy เพื่อประเมินราคา</p>
		{
			!configured ? (
				<p class="hint">
					ตั้งค่า <code>PUBLIC_WORDPRESS_URL</code> ใน <code>.env</code>{' '}
					เพื่อดึงโพสต์จาก WordPress
				</p>
			) : posts.length === 0 ? (
				<p class="hint">ยังไม่มีโพสต์ หรือ API ไม่สามารถเชื่อมต่อได้</p>
			) : (
				<p class="meta">{posts.length} บทความ</p>
			)
		}
	</div>

	{
		posts.length > 0 && (
			<div class="container grid">
				{posts.map((post) => (
					<PostCard post={post} />
				))}
			</div>
		)
	}
</BaseLayout>

<style>
	.page-head {
		padding-block: 2rem 1rem;
	}
	.page-title {
		margin: 0 0 0.5rem;
		font-size: clamp(1.5rem, 3vw, 2rem);
	}
	.intro {
		margin: 0 0 0.6rem;
		color: var(--muted);
		font-size: 0.95rem;
		max-width: 62ch;
	}
	.meta {
		margin: 0;
		font-family: var(--font-mono);
		color: var(--muted);
		font-size: 0.82rem;
		letter-spacing: 0.04em;
	}
	.hint {
		margin: 0;
		color: var(--muted);
		max-width: 48ch;
	}
	.hint code {
		font-family: var(--font-mono);
		font-size: 0.85em;
		padding: 0.15em 0.4em;
		background: rgba(15, 23, 42, 0.05);
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 6px;
		color: var(--accent-dim);
	}
	.grid {
		display: grid;
		gap: 1.25rem;
		padding-bottom: 4rem;
	}
	@media (min-width: 700px) {
		.grid {
			grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
		}
	}
</style>
