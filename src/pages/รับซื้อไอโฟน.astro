---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBox from '../components/ContactBox.astro';
import '../styles/longform.css';
import { getSiteOrigin } from '../lib/site';

const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'WE BUY | เรารับซื้อ';
const serviceAreasRaw =
	import.meta.env.PUBLIC_SERVICE_AREAS ??
	'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี,มหาสารคาม,สุรินทร์';
const serviceAreas = serviceAreasRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);

const faqItems = [
	{
		q: 'รับซื้อ iPhone รุ่นไหนบ้าง?',
		a: 'รับซื้อตั้งแต่ iPhone 8, 8 Plus, X, XR, XS, XS Max, 11, 11 Pro, 11 Pro Max, SE (รุ่น 2 และ 3), 12 mini, 12, 12 Pro, 12 Pro Max, 13 mini, 13, 13 Pro, 13 Pro Max, 14, 14 Plus, 14 Pro, 14 Pro Max, 15, 15 Plus, 15 Pro, 15 Pro Max, 16, 16 Plus, 16 Pro และ 16 Pro Max โดยประเมินจากรุ่น ความจุ สภาพเครื่อง และสุขภาพแบตเตอรี่',
	},
	{
		q: 'iPhone หน้าจอแตกหรือจอร้าวยังขายได้ไหม?',
		a: 'ขายได้ครับ ราคาจะขึ้นอยู่กับระดับความเสียหายของจอ เช่น จอร้าวเฉพาะกระจก หรือจอแสดงผลเสียหายด้วย ทีมงานจะแจ้งต้นทุนซ่อมที่คาดการณ์ได้ และอธิบายเหตุผลการประเมินราคาอย่างชัดเจนก่อนตกลง',
	},
	{
		q: 'ติด iCloud หรือ Find My iPhone รับซื้อไหม?',
		a: 'ต้องปลด iCloud และปิด Find My iPhone ก่อนส่งมอบครับ เพราะเครื่องที่ยังล็อกอยู่ไม่สามารถโอนกรรมสิทธิ์ให้เจ้าของใหม่ได้ตามปกติ หากไม่แน่ใจวิธีปลด สามารถสอบถามขั้นตอนกับทีมงานได้ก่อน',
	},
	{
		q: 'สุขภาพแบตเตอรี่ต่ำมากมีผลต่อราคาไหม?',
		a: 'มีผลครับ แบตเตอรี่ที่สุขภาพต่ำกว่า 80% จะถูกปรับราคาลง เพราะผู้ใช้งานต่อจะต้องเปลี่ยนแบตในอนาคตอันใกล้ แนะนำเช็กสุขภาพแบตจากเมนูตั้งค่า > แบตเตอรี่ > สุขภาพแบตเตอรี่ แล้วแจ้งตัวเลขตอนส่งข้อมูลมาประเมิน',
	},
	{
		q: 'iPhone เครื่องศูนย์ไทย (TH) กับเครื่องนอก ราคาต่างกันไหม?',
		a: 'ต่างกันครับ เครื่องศูนย์ไทย (TH/A) โดยทั่วไปจะได้ราคาสูงกว่าเครื่องนอก เพราะมีการรับประกันศูนย์ Apple ในไทยและเป็นที่ต้องการของตลาดมากกว่า เครื่องนอก เช่น LL/A (อเมริกา) หรือ ZP/A (ฮ่องกง) ยังรับซื้อได้ แต่ราคาจะปรับตามความต้องการตลาด',
	},
	{
		q: 'ขายด่วนต้องส่งข้อมูลอะไรบ้าง?',
		a: 'ส่งรุ่นเต็ม (เช่น iPhone 15 Pro Max 256GB), สุขภาพแบตเตอรี่, เวอร์ชัน iOS, สถานะ Face ID/True Tone, จุดตำหนิ (ถ้ามี), รูปเครื่องทุกมุม และวิดีโอสั้นทดสอบการใช้งานเบื้องต้น ส่งผ่าน Line @webuy ได้เลย ทีมงานพร้อมประเมินภายในไม่กี่นาที',
	},
	{
		q: 'Face ID เสียหรือ True Tone หายมีผลต่อราคามากไหม?',
		a: 'มีผลครับ Face ID ที่ใช้งานไม่ได้จะปรับราคาลงค่อนข้างมาก เพราะเป็นฟีเจอร์สำคัญที่ซ่อมยาก ส่วน True Tone ที่หายไปหลังเปลี่ยนจอนอกศูนย์จะกระทบราคาเช่นกัน แต่น้อยกว่า Face ID ทีมงานจะอธิบายเหตุผลและตัวเลขที่ปรับให้ชัดเจน',
	},
	{
		q: 'iPhone ติดล็อกซิม (Locked) รับซื้อไหม?',
		a: 'รับซื้อครับ แต่ราคาจะต่ำกว่าเครื่อง Unlocked (ใช้ได้ทุกซิม) เนื่องจากเครื่องล็อกซิมมีข้อจำกัดเรื่องเครือข่ายที่ใช้งานได้ หากสามารถปลดล็อกซิมก่อนขายจะได้ราคาดีกว่า',
	},
	{
		q: 'อยู่ต่างจังหวัดขายได้ไหม?',
		a: 'ขายได้ครับ สามารถส่งรูปและข้อมูลเครื่องผ่าน Line @webuy เพื่อประเมินราคาล่วงหน้า แล้วนัดหมายหรือจัดส่งตามที่สะดวก ทีมงานให้บริการทั่วประเทศ ติดต่อได้ 24 ชั่วโมง',
	},
	{
		q: 'ต้องเตรียมอะไรก่อนขาย iPhone?',
		a: 'สำรองข้อมูลขึ้น iCloud หรือคอมพิวเตอร์ ออกจาก Apple ID ปิด Find My iPhone ถอดซิมการ์ดออก รีเซ็ตเครื่องเป็นค่าโรงงาน และตรวจว่าหน้าจอต้อนรับ (Hello) ขึ้นมาเรียบร้อย เท่านี้เครื่องก็พร้อมส่งมอบครับ',
	},
];

const articleJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: 'รับซื้อไอโฟน iPhone มือสอง ทุกรุ่น ได้ราคาสูง จ่ายเงินทันที',
		description:
			'บริการรับซื้อ iPhone มือสองทุกรุ่นตั้งแต่ iPhone 8 ถึง iPhone 16 Pro Max ประเมินราคาโปร่งใส ดูจากรุ่น ความจุ สุขภาพแบต สภาพจอ Face ID True Tone สถานะ iCloud พร้อมคู่มือเตรียมเครื่องก่อนขายอย่างละเอียด',
		inLanguage: 'th-TH',
		author: { '@type': 'Organization', name: orgName },
		publisher: { '@type': 'Organization', name: orgName },
		mainEntityOfPage: `${site}/ไอโฟน/`,
		datePublished: '2026-03-24',
		dateModified: '2026-03-24',
		image: [new URL('/og-default.png', site).toString()],
		keywords:
			'รับซื้อไอโฟน, ขายไอโฟนมือสอง, รับซื้อ iPhone, ประเมินราคาไอโฟน, รับซื้อ iPhone มือสอง, ขาย iPhone ได้ราคาดี, รับซื้อไอโฟนจอแตก, รับซื้อ iPhone ทุกรุ่น, รับซื้อไอโฟนแบตเสื่อม, ขายไอโฟนเก่า',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.q,
			acceptedAnswer: { '@type': 'Answer', text: item.a },
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'บริการรับซื้อไอโฟน',
		description:
			'บริการรับซื้อ iPhone มือสองทุกรุ่น ตั้งแต่ iPhone 8 ถึง iPhone 16 Pro Max ทั้งเครื่องไทยและเครื่องนอก ประเมินราคาโปร่งใส จ่ายเงินทันที',
		provider: { '@type': 'Organization', name: orgName },
		areaServed: serviceAreas.map((area) => ({ '@type': 'AdministrativeArea', name: area })),
		serviceType: 'รับซื้อ iPhone มือสอง',
		url: `${site}/ไอโฟน/`,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
			{ '@type': 'ListItem', position: 2, name: 'รับซื้อไอโฟน', item: `${site}/ไอโฟน/` },
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'วิธีขาย iPhone มือสองกับ WE BUY',
		description: 'ขั้นตอนง่าย ๆ ในการขายไอโฟนมือสองให้ได้ราคาดี',
		step: [
			{
				'@type': 'HowToStep',
				name: 'ส่งข้อมูลเครื่อง',
				text: 'แอดไลน์ @webuy แล้วส่งรูปเครื่อง รุ่น ความจุ สภาพเครื่อง และ Battery Health',
			},
			{
				'@type': 'HowToStep',
				name: 'รับราคาประเมิน',
				text: 'ทีมงานตรวจสอบข้อมูลและแจ้งราคาประเมินให้รวดเร็ว',
			},
			{
				'@type': 'HowToStep',
				name: 'เตรียมเครื่อง',
				text: 'สำรองข้อมูล ออกจากระบบ iCloud และปิด Find My iPhone',
			},
			{
				'@type': 'HowToStep',
				name: 'รับเงินทันที',
				text: 'ตรวจสอบเครื่องจริงและรับเงินโอนหรือเงินสดทันที',
			},
		],
	},
];
---

<BaseLayout
	title="รับซื้อไอโฟน | รับซื้อ iPhone มือสอง ทุกรุ่น ได้ราคาสูง | WE BUY"
	description="WE BUY รับซื้อ iPhone มือสองทุกรุ่น iPhone 8 ถึง 16 Pro Max ประเมินราคาโปร่งใส จ่ายเงินทันที ดูจากรุ่น ความจุ Battery Health ติดต่อ Line @webuy 24 ชม."
	pathname="/ไอโฟน/"
	type="article"
	jsonLd={articleJsonLd}
>
	<article class="container longform">
		<header>
			<p class="kicker">iPhone Buyback Guide</p>
			<h1>รับซื้อไอโฟน (iPhone) มือสอง ทุกรุ่น ทุกความจุ ประเมินราคาโปร่งใส จ่ายเงินทันที</h1>
			<p class="intro">
				ถ้าคุณกำลังค้นหาคำว่า <strong>รับซื้อไอโฟน</strong> หรือ <strong>ขายไอโฟนมือสอง</strong> แสดงว่าคุณอาจกำลังอยู่ในช่วงตัดสินใจ
				ไม่ว่าจะอยากเปลี่ยนรุ่นใหม่ ต้องการเงินสดเร่งด่วน หรือมี iPhone เก่าวางทิ้งไว้จนลืมว่ามีอยู่ ปัญหาที่คนส่วนใหญ่เจอคือ
				ไม่แน่ใจว่าเครื่องตัวเองจะได้ราคาเท่าไร กลัวถูกกดราคา กลัวข้อมูลส่วนตัวจะหลุด และไม่รู้ว่าต้องเตรียมอะไรก่อนขาย
				บทความนี้เขียนขึ้นเพื่อตอบทุกคำถามเหล่านั้นอย่างละเอียดที่สุด ตั้งแต่ปัจจัยที่มีผลต่อราคา รุ่นที่รับซื้อ วิธีเช็กเครื่อง
				การเตรียมตัวก่อนขาย ไปจนถึงเรื่องที่หลายคนไม่รู้อย่างความแตกต่างระหว่างเครื่องศูนย์ไทยกับเครื่องนอก
				เครื่องล็อกซิมกับเครื่องปลดล็อก และราคาเครื่องจอแตก อ่านจบแล้วคุณจะตัดสินใจได้อย่างมั่นใจ
				หรือถ้าพร้อมขายเลย ทักมาที่ <a class="inline-contact" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">Line @webuy</a>
				หรือโทร <a class="phone-link" href="tel:0642579353">064-257-9353</a> ได้ตลอด 24 ชั่วโมง
			</p>
		</header>

		<!-- ==================== Section 1 ==================== -->
		<section>
			<h2>ทำไมต้องขายไอโฟนมือสองกับเรา</h2>
			<p>
				ตลาดรับซื้อ iPhone มือสองในประเทศไทยมีผู้เล่นหลายราย ทั้งร้านหน้าร้านในห้างสรรพสินค้า
				กลุ่มซื้อขายออนไลน์ และบริการรับซื้อผ่านแอปพลิเคชัน แต่สิ่งที่ลูกค้าหลายคนบอกเราว่า
				ทำให้เลือกใช้บริการของเราซ้ำแล้วซ้ำเล่าคือ "ความชัดเจนของราคาและเหตุผลประกอบ"
				เราไม่ได้แค่บอกตัวเลขราคาลอย ๆ แล้วให้ตัดสินใจ แต่อธิบายเป็นข้อ ๆ ว่าราคาเกิดจากอะไร
				เช่น รุ่นและความจุให้ฐานราคาเท่าไร สุขภาพแบตเตอรี่ปรับเท่าไร สภาพจอกระทบอย่างไร
				Face ID ใช้งานได้หรือไม่ True Tone ยังอยู่ไหม และสถานะ iCloud เป็นอย่างไร
				ทุกรายการมีคำอธิบายประกอบ ไม่มีค่าใช้จ่ายแฝง และไม่มีการปรับราคาหน้างานแบบเซอร์ไพรส์
			</p>
			<h3>ข้อดีที่คุณจะได้รับเมื่อขายกับเรา</h3>
			<ul>
				<li>ประเมินราคาฟรี ไม่มีค่าธรรมเนียม ส่งรูปมาทาง Line ก็ได้ราคาเบื้องต้นภายในไม่กี่นาที</li>
				<li>จ่ายเงินทันทีหลังตรวจสภาพเสร็จ ไม่ต้องรอโอน ไม่ต้องรอเช็ค</li>
				<li>รับซื้อทุกรุ่น ทุกความจุ ทุกสี ทั้งเครื่องสมบูรณ์และเครื่องมีตำหนิ</li>
				<li>ให้บริการ 24 ชั่วโมง ทุกวัน ไม่มีวันหยุด ทักมาเมื่อไรก็ได้</li>
				<li>ให้บริการทั่วประเทศ ทั้ง {serviceAreas.join(', ')} และพื้นที่อื่น ๆ</li>
			</ul>
			<p>
				เราเข้าใจว่าการขายไอโฟนไม่ใช่แค่เรื่องเงิน แต่เป็นเรื่องความไว้วางใจด้วย คุณต้องมั่นใจว่า
				ข้อมูลส่วนตัวจะปลอดภัย ราคาที่ได้ยุติธรรม และกระบวนการทั้งหมดโปร่งใสตรวจสอบได้
				นั่นคือเหตุผลที่เราเน้นการสื่อสารที่ชัดเจนตั้งแต่ข้อความแรกที่คุยกัน
				สนใจประเมินราคาเครื่องของคุณ ทักมาได้เลยที่ <a class="inline-contact" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">Line @webuy</a>
				หรือโทรสอบถามที่ <a class="phone-link" href="tel:0642579353">064-257-9353</a>
			</p>
		</section>

		<!-- ==================== Section 2 ==================== -->
		<section>
			<h2>ปัจจัยที่มีผลต่อราคารับซื้อ iPhone มือสอง</h2>
			<p>
				ราคา iPhone มือสองไม่ได้ถูกกำหนดจากปัจจัยเดียว แต่เกิดจากหลายตัวแปรที่ประเมินร่วมกัน
				การเข้าใจปัจจัยเหล่านี้จะช่วยให้คุณรู้ว่า "ทำไมเครื่องของฉันได้ราคาเท่านี้" และ
				สามารถเปรียบเทียบข้อเสนอจากหลายแหล่งได้อย่างมีเหตุผล ไม่ใช่ดูแค่ตัวเลขสูงสุด
			</p>

			<h3>รุ่นและความจุ (Model & Storage Capacity)</h3>
			<p>
				รุ่นของ iPhone เป็นปัจจัยแรกที่กำหนดฐานราคา โดยรุ่นใหม่กว่ามักได้ราคาสูงกว่า
				ตัวอย่างเช่น iPhone 15 Pro Max จะได้ราคาสูงกว่า iPhone 13 Pro Max อย่างเห็นได้ชัด
				แม้สภาพจะเหมือนกัน เพราะชิปเซ็ต กล้อง และฟีเจอร์ต่าง ๆ ของรุ่นใหม่ตอบโจทย์ผู้ใช้ได้ดีกว่า
				ความจุก็มีผลมากเช่นกัน เครื่อง 256GB จะได้ราคาดีกว่า 128GB เสมอ
				และ 512GB หรือ 1TB จะมีมูลค่าเพิ่มขึ้นตามลำดับ
			</p>

			<h3>สุขภาพแบตเตอรี่ (Battery Health)</h3>
			<p>
				สุขภาพแบตเตอรี่เป็นตัวเลขที่ผู้รับซื้อทุกรายดูเป็นอย่างแรก ๆ เพราะมันบ่งบอกว่า
				เครื่องนี้เคยถูกใช้งานหนักแค่ไหน และผู้ใช้คนต่อไปจะต้องเปลี่ยนแบตเร็วแค่ไหน
				เครื่องที่มีสุขภาพแบต 90% ขึ้นไปมักได้ราคาดี ส่วนเครื่องที่แบตต่ำกว่า 80%
				จะถูกปรับราคาลงเพราะต้องเผื่อค่าเปลี่ยนแบตในอนาคต วิธีเช็กง่ายมาก
				ไปที่ ตั้งค่า > แบตเตอรี่ > สุขภาพแบตเตอรี่ แล้วดูตัวเลข Maximum Capacity
			</p>

			<h4>เครื่องที่แบตถูกเปลี่ยนมาแล้ว</h4>
			<p>
				ถ้าเคยเปลี่ยนแบตเตอรี่มาแล้ว ไม่ว่าจะเปลี่ยนศูนย์ Apple หรือร้านนอก จะมีผลต่อราคาต่างกัน
				เครื่องที่เปลี่ยนแบตศูนย์จะไม่แสดงข้อความเตือนชิ้นส่วนไม่แท้ และมักได้ราคาใกล้เคียงเครื่องปกติ
				แต่เครื่องที่เปลี่ยนแบตร้านนอกอาจแสดงข้อความเตือนในเมนูแบตเตอรี่
				ซึ่งจะทำให้ราคาปรับลงบ้าง เพราะผู้รับซื้อต้องเผื่อความเสี่ยง
			</p>

			<h3>สภาพหน้าจอ (Screen Condition)</h3>
			<p>
				หน้าจอเป็นส่วนที่ผู้ใช้มองเห็นและสัมผัสทุกวัน เครื่องที่จอสวยไม่มีรอยจะได้ราคาดีที่สุด
				เครื่องที่มีรอยขีดข่วนเล็กน้อยจากการใช้งานปกติมักไม่กระทบราคามาก
				แต่ถ้าจอมีรอยร้าว จอแตก หรือมี dead pixel จะถูกปรับราคาลงตามระดับความเสียหาย
				เราจะอธิบายรายละเอียดเรื่องเครื่องจอแตกเพิ่มเติมในหัวข้อถัดไป
			</p>

			<h3>Face ID และ True Tone</h3>
			<h4>Face ID</h4>
			<p>
				Face ID เป็นระบบสแกนใบหน้าที่ Apple ออกแบบมาอย่างซับซ้อน ถ้า Face ID ใช้งานไม่ได้
				ราคาจะถูกปรับลงค่อนข้างมาก เพราะเป็นฟีเจอร์ที่ซ่อมยากมากและต้นทุนสูง
				ผู้ใช้งานจำนวนมากถือว่า Face ID เป็นฟีเจอร์จำเป็น ทั้งสำหรับปลดล็อกเครื่อง
				ยืนยันการจ่ายเงิน Apple Pay และล็อกอินแอปธนาคาร
			</p>
			<h4>True Tone</h4>
			<p>
				True Tone เป็นฟีเจอร์ที่ปรับอุณหภูมิสีจอให้เข้ากับแสงรอบข้างอัตโนมัติ
				ฟีเจอร์นี้จะหายไปถ้าเปลี่ยนจอนอกศูนย์โดยไม่ได้ย้ายข้อมูลชิปจอเดิม
				แม้จะไม่กระทบการใช้งานหลัก แต่ผู้ซื้อหลายคนให้ความสำคัญ เพราะมันบ่งบอกว่า
				จอเป็นของแท้หรือเคยถูกเปลี่ยนมาก่อน ราคาจึงปรับลงบ้างในกรณีที่ True Tone หายไป
			</p>

			<h3>สถานะ iCloud Lock</h3>
			<p>
				เครื่องที่ยังติดล็อก iCloud หรือยังไม่ได้ปิด Find My iPhone จะกระทบราคาอย่างมาก
				เพราะเครื่องล็อก iCloud ไม่สามารถใช้งานได้ตามปกติ ผู้รับซื้อส่วนใหญ่จะไม่รับเครื่องที่ยังติดล็อก
				เว้นแต่จะรับในราคาต่ำมากเพื่อนำไปเป็นอะไหล่ ก่อนขายจึงต้องออกจาก Apple ID
				และปิด Find My iPhone ให้เรียบร้อยทุกครั้ง
			</p>

			<div class="highlight-box">
				<strong>เคล็ดลับ:</strong> ก่อนติดต่อประเมินราคา ให้เตรียมข้อมูล 5 อย่างนี้ไว้เลย —
				รุ่นเต็ม + ความจุ, สุขภาพแบตเตอรี่, สภาพจอ, สถานะ Face ID/True Tone, และสถานะ iCloud
				ข้อมูลครบตั้งแต่แรก = ได้ราคาเร็วและแม่นยำ
			</div>
		</section>

