		<script is:inline>
			(function () {
				const toggle = document.querySelector('.nav-toggle');
				const nav = document.getElementById('main-nav');
				const groups = Array.from(document.querySelectorAll('.nav-group'));
				if (!toggle || !nav) return;
				const mq = window.matchMedia('(max-width: 1023px)');

				function syncInert() {
					if (!mq.matches) {
						nav.removeAttribute('inert');
						return;
					}
					if (toggle.getAttribute('aria-expanded') === 'true') nav.removeAttribute('inert');
					else nav.setAttribute('inert', '');
				}

				function setExpanded(open) {
					toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
					toggle.setAttribute('aria-label', open ? 'ปิดเมนู' : 'เปิดเมนู');
					nav.classList.toggle('nav--open', open);
					syncInert();
					if (!open) groups.forEach((g) => g.removeAttribute('open'));
				}

				toggle.addEventListener('click', function () {
					const open = toggle.getAttribute('aria-expanded') !== 'true';
					setExpanded(open);
				});

				nav.querySelectorAll('a').forEach(function (link) {
					link.addEventListener('click', function () {
						if (mq.matches) setExpanded(false);
					});
				});

				document.addEventListener('click', function (e) {
					if (mq.matches) return;
					const t = e.target;
					if (!t || !(t instanceof Node)) return;
					groups.forEach((g) => {
						if (!g.contains(t)) g.removeAttribute('open');
					});
				});

				mq.addEventListener('change', function (e) {
					if (!e.matches) setExpanded(false);
					else syncInert();
				});

				syncInert();

				document.addEventListener('keydown', function (e) {
					if (e.key === 'Escape' && mq.matches) setExpanded(false);
					if (e.key === 'Escape' && !mq.matches) groups.forEach((g) => g.removeAttribute('open'));
				});
			})();
		</script>
