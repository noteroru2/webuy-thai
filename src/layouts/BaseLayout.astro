---
import { getSiteOrigin } from '../lib/site';
import BrandLogo from '../components/BrandLogo.astro';
import '../styles/fonts.css';
interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	pathname?: string;
	type?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
	jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
	noindex?: boolean;
}

const {
	title,
	description = 'เว็บไซต์ที่ขับเคลื่อนโดย Astro + WordPress',
	ogImage,
	pathname = Astro.url.pathname,
	type = 'website',
	publishedTime,
	modifiedTime,
	jsonLd,
	noindex = false,
} = Astro.props;

const site = new URL(getSiteOrigin());
const canonicalUrl = new URL(pathname, site).toString();
const defaultImage = '/og-default.png';
const imageUrl = new URL(ogImage ?? defaultImage, site).toString();
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'เรารับซื้อ.com';
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'WE BUY | เรารับซื้อ';
const locale = import.meta.env.PUBLIC_SITE_LOCALE ?? 'th_TH';
const twitterSite = import.meta.env.PUBLIC_TWITTER_SITE;
const robotsContent = noindex
	? 'noindex, nofollow, noarchive'
	: 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
---

<!doctype html>
<html lang="th">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/logo-we-buy.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#ff8c00" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="author" content={orgName} />
		<meta name="robots" content={robotsContent} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="th" href={canonicalUrl} />
		<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
		<meta property="og:type" content={type} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content={locale} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		{twitterSite && <meta name="twitter:site" content={twitterSite} />}
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
		{type === 'article' && <meta property="article:author" content={orgName} />}
		<title>{title}</title>
		<slot name="head" />
		{jsonLd &&
			(Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map((item) => (
				<script type="application/ld+json" set:html={JSON.stringify(item)} />
			))}
		<style is:global>
			:root {
				--bg: #fafbfd;
				--bg-warm: #fff8f3;
				--surface: #ffffff;
				--ink: #0f172a;
				--text: #141414;
				--muted: #525252;
				--accent: #ff8c00;
				--accent-bright: #ff9500;
				--accent-dim: #e67300;
				--accent-soft: rgba(255, 140, 0, 0.12);
				--accent-soft-strong: rgba(255, 140, 0, 0.18);
				--accent-glow: rgba(255, 149, 0, 0.22);
				--radius: 14px;
				--font: 'IBM Plex Sans Thai', 'IBM Plex Sans', system-ui, sans-serif;
				--font-mono: 'IBM Plex Mono', ui-monospace, 'Cascadia Code', 'SF Mono', Menlo, monospace;
				--shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.05);
				--shadow-md: 0 10px 40px rgba(15, 23, 42, 0.07);
				--shadow-tech: 0 0 0 1px rgba(255, 140, 0, 0.08), 0 12px 40px rgba(15, 23, 42, 0.06);
			}
			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				min-height: 100vh;
				font-family: var(--font);
				color: var(--text);
				line-height: 1.6;
				background-color: var(--bg);
				background-image: linear-gradient(180deg, var(--bg-warm) 0%, transparent 38%),
					radial-gradient(ellipse 120% 70% at 50% -35%, var(--accent-glow) 0%, transparent 58%),
					linear-gradient(rgba(15, 23, 42, 0.035) 1px, transparent 1px),
					linear-gradient(90deg, rgba(15, 23, 42, 0.035) 1px, transparent 1px);
				background-size: 100% 100%, 100% 100%, 40px 40px, 40px 40px;
				background-position: 0 0, 0 0, 0 0, 0 0;
			}
			a {
				color: var(--accent);
				text-decoration: none;
			}
			a:hover {
				text-decoration: underline;
			}
			.container {
				width: min(960px, 92vw);
				margin-inline: auto;
				padding-block: 2rem 4rem;
			}
			.skip-link {
				position: absolute;
				left: 12px;
				top: 12px;
				transform: translateY(-140%);
				background: var(--surface);
				color: var(--text);
				border: 2px solid var(--accent);
				border-radius: 12px;
				padding: 0.55rem 0.8rem;
				font-weight: 700;
				z-index: 100;
				box-shadow: 0 10px 24px rgba(20, 30, 45, 0.18);
			}
			.skip-link:focus {
				transform: translateY(0);
			}
			.site-header {
				position: sticky;
				top: 0;
				z-index: 100;
				border-bottom: 1px solid rgba(15, 23, 42, 0.06);
				padding-block: 0;
				background: rgba(255, 255, 255, 0.86);
				backdrop-filter: blur(14px) saturate(1.2);
				box-shadow: 0 1px 0 rgba(255, 140, 0, 0.12), var(--shadow-sm);
			}
			.header-top {
				border-bottom: 1px solid rgba(255, 140, 0, 0.1);
			}
			.header-mobile-cta {
				display: none;
			}
			.header-top-inner {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.75rem 1rem;
				width: min(960px, 92vw);
				margin-inline: auto;
				padding-block: 0.85rem;
				position: relative;
			}
			@media (min-width: 1024px) {
				.header-top-inner {
					display: grid;
					grid-template-columns: minmax(0, 18rem) 1fr auto;
					align-items: center;
					gap: 1.25rem 1.5rem;
				}
				.brand,
				.nav--main,
				.header-util {
					order: 0;
				}
				.brand {
					grid-column: 1;
				}
				.nav--main {
					grid-column: 2;
					justify-self: center;
				}
				.header-util {
					grid-column: 3;
					justify-self: end;
				}
			}
			.header-util {
				display: flex;
				align-items: center;
				gap: 0.35rem;
				flex-shrink: 0;
			}
			.util-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 2.45rem;
				height: 2.45rem;
				padding: 0;
				border-radius: 10px;
				border: 1px solid rgba(36, 48, 67, 0.1);
				background: var(--surface);
				color: var(--muted);
				text-decoration: none;
				box-shadow: 0 1px 2px rgba(36, 48, 67, 0.05);
				transition:
					background 0.2s,
					border-color 0.2s,
					color 0.2s;
			}
			.util-btn:hover {
				background: var(--accent-soft);
				border-color: rgba(255, 140, 0, 0.35);
				color: var(--accent-dim);
				text-decoration: none;
			}
			.util-btn:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			.util-btn svg {
				width: 1.1rem;
				height: 1.1rem;
			}
			.util-btn--line {
				width: auto;
				min-height: 2.45rem;
				padding: 0 0.7rem;
				font-size: 0.72rem;
				font-weight: 800;
				letter-spacing: 0.04em;
				font-family: var(--font-mono);
				text-transform: uppercase;
				background: #0a8a46;
				color: #fff;
				border-color: rgba(255, 255, 255, 0.2);
			}
			.util-btn--line:hover {
				background: #087a3e;
				color: #fff;
				border-color: rgba(255, 255, 255, 0.28);
			}
			.header-sub {
				background: linear-gradient(
					90deg,
					rgba(255, 236, 210, 0.92) 0%,
					#fff5e8 45%,
					rgba(255, 228, 196, 0.88) 100%
				);
				border-bottom: 1px solid rgba(255, 140, 0, 0.16);
				box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
			}
			.header-sub-wrap {
				width: min(960px, 92vw);
				margin-inline: auto;
				padding-inline: max(0.65rem, env(safe-area-inset-left)) max(0.65rem, env(safe-area-inset-right));
				padding-block: 0.55rem 0.5rem;
			}
			.header-sub-inner {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.65rem 1rem;
			}
			.sub-home {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 2.65rem;
				height: 2.65rem;
				flex-shrink: 0;
				border-radius: 12px;
				color: var(--accent);
				background: #ffffff;
				border: 1px solid rgba(255, 140, 0, 0.42);
				box-shadow: 0 1px 2px rgba(255, 119, 0, 0.08);
				text-decoration: none;
			}
			.sub-home:hover {
				background: #fffdfa;
				border-color: rgba(255, 140, 0, 0.6);
				color: var(--accent-dim);
				text-decoration: none;
			}
			.sub-home svg {
				width: 1.15rem;
				height: 1.15rem;
			}
			.header-sub-copy {
				flex: 1 1 min(100%, 12rem);
				min-width: 0;
			}
			.header-sub-msg {
				margin: 0;
				font-size: clamp(0.88rem, 2.4vw, 1rem);
				font-weight: 650;
				color: #3d3328;
				line-height: 1.45;
			}
			.header-sub-msg a {
				color: var(--accent-dim);
				font-weight: 750;
				text-decoration: underline;
				text-underline-offset: 3px;
			}
			.header-sub-msg a:hover {
				color: var(--accent);
				text-decoration: underline;
			}
			.header-sub-actions {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.45rem;
				flex-shrink: 0;
			}
			.sub-cta {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 2.5rem;
				padding: 0.45rem 0.85rem;
				border-radius: 999px;
				font-size: 0.82rem;
				font-weight: 750;
				text-decoration: none;
				white-space: nowrap;
				box-sizing: border-box;
			}
			.sub-cta--line {
				background: #0a8a46;
				color: #fff;
				border: 1px solid rgba(255, 255, 255, 0.22);
			}
			.sub-cta--line:hover {
				background: #087a3e;
				color: #fff;
				text-decoration: none;
			}
			.sub-cta--tel {
				background: #fff;
				color: #b45300;
				border: 1px solid rgba(255, 140, 0, 0.28);
			}
			.sub-cta--tel:hover {
				background: #fffaf3;
				color: #8a3d00;
				text-decoration: none;
			}
			@media (max-width: 1023px) {
				.header-top-inner {
					padding-block: 0.75rem 0.35rem;
				}
				.header-mobile-cta {
					display: flex;
					flex-wrap: wrap;
					gap: 0.5rem;
					width: min(960px, 92vw);
					margin-inline: auto;
					padding: 0 max(0.65rem, env(safe-area-inset-left)) 0.65rem
						max(0.65rem, env(safe-area-inset-right));
				}
				.header-mobile-cta__btn {
					flex: 1 1 calc(50% - 0.25rem);
					min-width: min(100%, 9.5rem);
					min-height: 2.75rem;
					display: inline-flex;
					align-items: center;
					justify-content: center;
					padding: 0.5rem 0.75rem;
					border-radius: 12px;
					font-size: 0.88rem;
					font-weight: 750;
					text-decoration: none;
					box-sizing: border-box;
					transition:
						transform 0.15s ease,
						box-shadow 0.15s ease;
				}
				.header-mobile-cta__btn:active {
					transform: scale(0.98);
				}
				.header-mobile-cta__btn--line {
					background: #0a8a46;
					color: #fff;
					border: 1px solid rgba(255, 255, 255, 0.22);
					box-shadow: 0 2px 8px rgba(6, 120, 53, 0.22);
				}
				.header-mobile-cta__btn--line:hover {
					background: #087a3e;
					color: #fff;
					text-decoration: none;
				}
				.header-mobile-cta__btn--tel {
					background: #fff;
					color: #b45300;
					border: 1px solid rgba(255, 140, 0, 0.35);
					box-shadow: 0 2px 8px rgba(255, 119, 0, 0.12);
				}
				.header-mobile-cta__btn--tel:hover {
					background: #fffaf3;
					color: #8a3d00;
					text-decoration: none;
				}
				.header-util .util-btn--phone,
				.header-util .util-btn--line {
					display: none;
				}
				.header-sub-actions {
					display: none;
				}
				.header-sub-wrap {
					padding-block: 0.45rem 0.48rem;
				}
				.header-sub-inner {
					align-items: flex-start;
					gap: 0.5rem 0.65rem;
				}
				.header-sub-copy {
					flex: 1 1 0;
					min-width: 0;
					padding-top: 0.12rem;
				}
				.header-sub-msg {
					font-size: 0.9rem;
					line-height: 1.5;
				}
				.sub-home {
					width: 2.4rem;
					height: 2.4rem;
					border-radius: 10px;
				}
			}
			.nav-toggle {
				display: none;
				align-items: center;
				justify-content: center;
				width: 2.75rem;
				height: 2.75rem;
				padding: 0;
				border: 1px solid rgba(36, 48, 67, 0.12);
				border-radius: 10px;
				background: var(--surface);
				color: var(--text);
				cursor: pointer;
				flex-shrink: 0;
				box-shadow: 0 1px 3px rgba(36, 48, 67, 0.06);
				transition:
					background 0.2s,
					border-color 0.2s,
					box-shadow 0.2s;
			}
			.nav-toggle:hover {
				background: #faf8f4;
				border-color: rgba(255, 140, 0, 0.35);
			}
			.nav-toggle:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			.nav-toggle-bars {
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 5px;
				width: 1.15rem;
			}
			.nav-toggle-bars span {
				display: block;
				height: 2px;
				width: 100%;
				border-radius: 1px;
				background: currentColor;
				transition:
					transform 0.22s ease,
					opacity 0.2s ease;
				transform-origin: center;
			}
			.nav-toggle[aria-expanded='true'] .nav-toggle-bars span:nth-child(1) {
				transform: translateY(7px) rotate(45deg);
			}
			.nav-toggle[aria-expanded='true'] .nav-toggle-bars span:nth-child(2) {
				opacity: 0;
				transform: scaleX(0);
			}
			.nav-toggle[aria-expanded='true'] .nav-toggle-bars span:nth-child(3) {
				transform: translateY(-7px) rotate(-45deg);
			}
			.nav {
				display: flex;
				flex-wrap: nowrap;
				gap: 1.25rem;
				align-items: center;
				min-height: 2.75rem;
			}
			.nav a {
				color: var(--muted);
				font-weight: 600;
				font-size: 0.9rem;
				letter-spacing: 0.02em;
			}
			.nav-group {
				position: relative;
			}
			.nav-group summary {
				list-style: none;
				cursor: pointer;
				color: var(--muted);
				font-weight: 600;
				padding: 0.4rem 0.55rem;
				border-radius: 10px;
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				user-select: none;
			}
			.nav-group summary::-webkit-details-marker {
				display: none;
			}
			.nav-group summary:hover,
			.nav-group[open] summary {
				background: var(--accent-soft);
				color: var(--accent-dim);
			}
			.nav-caret {
				width: 0.8rem;
				height: 0.8rem;
				opacity: 0.8;
				transition: transform 0.2s ease;
			}
			.nav-group[open] .nav-caret {
				transform: rotate(180deg);
			}
			.nav-dropdown {
				position: absolute;
				top: calc(100% + 0.55rem);
				right: 0;
				min-width: 17rem;
				padding: 0.55rem;
				border: 1px solid rgba(15, 23, 42, 0.08);
				border-radius: var(--radius);
				background: rgba(255, 255, 255, 0.96);
				backdrop-filter: blur(12px);
				box-shadow: var(--shadow-tech);
				display: grid;
				gap: 0.25rem;
				z-index: 80;
			}
			.nav-dropdown a {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0.7rem 0.75rem;
				border-radius: 12px;
				color: var(--text);
				font-weight: 650;
				text-decoration: none;
			}
			.nav-dropdown a:hover,
			.nav-dropdown a:focus-visible {
				background: var(--accent-soft);
				color: var(--accent-dim);
				text-decoration: none;
			}
			.nav-dropdown small {
				font-family: var(--font-mono);
				color: var(--muted);
				font-weight: 500;
				font-size: 0.72rem;
				letter-spacing: 0.04em;
				text-transform: uppercase;
				white-space: nowrap;
				opacity: 0.9;
			}
			.nav a:hover {
				color: var(--accent);
			}
			@media (max-width: 1023px) {
				.header-util {
					order: 1;
				}
				.nav-toggle {
					display: inline-flex;
					order: 2;
				}
				.nav--main {
					order: 10;
					flex: 1 1 100%;
				}
				.nav {
					flex-direction: column;
					align-items: stretch;
					width: 100%;
					margin-top: 0;
					padding: 0;
					gap: 0;
					max-height: 0;
					overflow: hidden;
					opacity: 0;
					visibility: hidden;
					pointer-events: none;
					transition:
						max-height 0.38s cubic-bezier(0.4, 0, 0.2, 1),
						opacity 0.28s ease,
						visibility 0.38s,
						padding 0.38s ease,
						margin 0.38s ease;
					border-top: 1px solid transparent;
				}
				.nav.nav--open {
					max-height: 28rem;
					opacity: 1;
					visibility: visible;
					pointer-events: auto;
					margin-top: 0.9rem;
					padding-top: 0.65rem;
					border-top-color: rgba(36, 48, 67, 0.1);
				}
				.nav a {
					display: flex;
					align-items: center;
					padding: 0.9rem 0.65rem;
					margin: 0 -0.65rem;
					border-radius: var(--radius);
					color: var(--text);
					font-weight: 600;
					font-size: 0.98rem;
					text-decoration: none;
					border-bottom: 1px solid rgba(36, 48, 67, 0.06);
					transition:
						background 0.15s ease,
						color 0.15s ease;
				}
				.nav a:last-child {
					border-bottom: none;
				}
				.nav a:hover,
				.nav a:focus-visible {
					background: var(--accent-soft);
					color: var(--accent-dim);
					text-decoration: none;
				}
				.nav-group {
					width: 100%;
				}
				.nav-group summary {
					width: 100%;
					padding: 0.95rem 0.65rem;
					margin: 0 -0.65rem;
					border-radius: var(--radius);
					color: var(--text);
					font-weight: 700;
					border-bottom: 1px solid rgba(36, 48, 67, 0.06);
				}
				.nav-dropdown {
					position: static;
					min-width: auto;
					border: none;
					box-shadow: none;
					padding: 0.35rem 0 0.65rem;
				}
				.nav-dropdown a {
					padding: 0.78rem 0.65rem;
					margin: 0 -0.65rem;
					border-radius: var(--radius);
					border: 1px solid rgba(36, 48, 67, 0.06);
				}
			}
			@media (min-width: 1024px) {
				.nav-toggle {
					display: none !important;
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.nav {
					transition: none;
				}
				.nav-toggle-bars span {
					transition: none;
				}
			}
			.line-float {
				position: fixed;
				right: max(14px, env(safe-area-inset-right));
				bottom: max(14px, env(safe-area-inset-bottom));
				z-index: 70;
